@model ProyectoGraduacionNomina.Jornada

@{
    ViewBag.Title = "Eliminar Jornada";
}

<div class="form-card mt-4">
    <div class="form-header">
        <h2 class="text-danger"><i class="bi bi-trash me-2"></i>Eliminar Jornada</h2>
    </div>

    <div class="form-body">
        <p class="text-danger">¿Está seguro de eliminar el rol <strong>@Model.nombre</strong>?</p>

        <dl class="row">
            <dt class="col-sm-4 fw-semibold">Jornada</dt>
            <dd class="col-sm-8">@Html.DisplayFor(m => m.nombre)</dd>

            <dt class="col-sm-4 fw-semibold">Horas semanales</dt>
            <dd class="col-sm-8">@Html.DisplayFor(m => m.horas_semanales)</dd>

            <dt class="col-sm-4 fw-semibold">Descripción</dt>
            <dd class="col-sm-8">@Html.DisplayFor(m => m.descripcion)</dd>
        </dl>
    </div>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="form-footer d-flex justify-content-between align-items-center mt-3">
            <a href="@Url.Action("Index")" class="btn btn-light cancel-btn">
                <i class="bi bi-arrow-left-circle me-1"></i> Cancelar
            </a>
            <button type="submit" class="btn btn-danger shadow-sm">
                <i class="bi bi-trash me-1"></i> Eliminar
            </button>
        </div>
    }
</div>
