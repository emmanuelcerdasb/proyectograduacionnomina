@model ProyectoGraduacionNomina.Jornada

@{
    ViewBag.Title = "Editar Jornada";
}

<div class="form-card mt-4">
    <div class="form-header">
        <h2><i class="bi bi-pencil-square me-2"></i> Editar Jornada</h2>
    </div>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        @Html.HiddenFor(m => m.idJornada)

        <div class="form-body">
            @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

            <div class="mb-3">
                @Html.LabelFor(m => m.nombre, "Nombre", new { @class = "form-label fw-semibold" })
                @Html.EditorFor(m => m.nombre, new { htmlAttributes = new { @class = "form-control modern-input" } })
                @Html.ValidationMessageFor(m => m.nombre, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(m => m.horas_semanales, "Horas semanales", new { @class = "form-label fw-semibold" })
                @Html.EditorFor(m => m.horas_semanales, new { htmlAttributes = new { @class = "form-control modern-input" } })
                @Html.ValidationMessageFor(m => m.horas_semanales, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(m => m.descripcion, "Descripción", new { @class = "form-label fw-semibold" })
                @Html.TextAreaFor(m => m.descripcion, new { @class = "form-control modern-input", rows = 3 })
                @Html.ValidationMessageFor(m => m.descripcion, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-footer d-flex justify-content-between align-items-center">
            <a href="@Url.Action("Index")" class="btn btn-light cancel-btn">
                <i class="bi bi-arrow-left-circle me-1"></i> Cancelar
            </a>
            <button type="submit" class="btn btn-primary-custom">
                <i class="bi bi-save2 me-1"></i> Actualizar
            </button>
        </div>
    }
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
