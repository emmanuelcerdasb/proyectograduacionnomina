@model ProyectoGraduacionNomina.Jornada

@{
    ViewBag.Title = "Crear Jornada";
}

<div class="form-card mt-4">
    <div class="form-header">
        <h2><i class="bi bi-calendar-week me-2"></i> Crear Jornada</h2>
    </div>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="form-body">
            @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

            <!-- Nombre -->
            <div class="mb-3">
                @Html.LabelFor(model => model.nombre, "Nombre de la jornada", new { @class = "form-label fw-semibold" })
                @Html.EditorFor(model => model.nombre, new { htmlAttributes = new { @class = "form-control modern-input", placeholder = "Ej. Jornada Diurna" } })
                @Html.ValidationMessageFor(model => model.nombre, "", new { @class = "text-danger" })
            </div>

            <!-- Horas semanales -->
            <div class="mb-3">
                @Html.LabelFor(model => model.horas_semanales, "Horas semanales", new { @class = "form-label fw-semibold" })
                @Html.EditorFor(model => model.horas_semanales, new { htmlAttributes = new { @class = "form-control modern-input", placeholder = "Ej. 40" } })
                @Html.ValidationMessageFor(model => model.horas_semanales, "", new { @class = "text-danger" })
            </div>

            <!-- Descripción -->
            <div class="mb-3">
                @Html.LabelFor(model => model.descripcion, "Descripción", new { @class = "form-label fw-semibold" })
                @Html.TextAreaFor(model => model.descripcion, new { @class = "form-control modern-input", rows = 3, placeholder = "Ej. Jornada laboral de 8am a 5pm de lunes a viernes" })
                @Html.ValidationMessageFor(model => model.descripcion, "", new { @class = "text-danger" })
            </div>
        </div>


        <div class="form-footer d-flex justify-content-between align-items-center">
            <a href="@Url.Action("Index")" class="btn btn-light cancel-btn">
                <i class="bi bi-arrow-left-circle me-1"></i> Volver
            </a>
            <button type="submit" class="btn btn-primary-custom">
                <i class="bi bi-save2 me-1"></i> Crear
            </button>
        </div>
    }
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
