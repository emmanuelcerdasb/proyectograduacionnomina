<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Sistema Nómina</title>

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Iconos -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- Fuente moderna -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <!-- CSS personalizado -->
    <link href="~/Content/Site.css?v=8" rel="stylesheet" />
</head>

<body>
    <!-- Botón hamburguesa (visible solo en móviles) -->
    <button class="btn-toggle-sidebar d-md-none" id="toggleSidebar">
        <i class="bi bi-list"></i>
    </button>

    <div class="d-flex" id="wrapper">
        <!-- Sidebar (Partial) -->
        @Html.Partial("_Sidebar")

        <!-- Contenido principal -->
        <div class="content flex-grow-1 p-4">
            <div class="topbar d-flex justify-content-between align-items-center mb-4">
                <h4 class="fw-semibold mb-0">@ViewBag.Title</h4>
                <div class="user-menu d-flex align-items-center gap-3">
                    @if (User.Identity.IsAuthenticated)
                    {
                        @Html.Action("Badge", "Notificacion")
                    }
                    else
                    {
                        <i class="bi bi-bell"></i>
                    }
                    <div class="dropdown">
                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false">
                                <img src="~/Content/user.png" class="rounded-circle" width="32" height="32" alt="User">
                                <span class="ms-2">@User.Identity.Name</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                                <li><a class="dropdown-item" href="#">Perfil</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("Logout", "Account")">Cerrar sesión</a></li>
                            </ul>
                        }
                        else
                        {
                            <a href="@Url.Action("Login", "Account")" class="d-flex align-items-center text-decoration-none">
                                <img src="~/Content/user.png" class="rounded-circle" width="32" height="32" alt="User">
                                <span class="ms-2">Ingresar</span>
                            </a>
                        }
                    </div>
                </div>
            </div>

            <div class="main-content">
                @RenderBody()
            </div>

            <footer class="mt-5 text-center text-muted small">
                &copy; @DateTime.Now.Year - Sistema Nómina
            </footer>
        </div>
    </div>


    <!-- ================================================================= -->
    <!-- 🔥 SISTEMA DE TOASTS - AUTOMÁTICO + GLOBAL PERSONALIZADO -->
    <!-- ================================================================= -->

    <div aria-live="polite" aria-atomic="true"
         class="position-fixed top-0 end-0 p-3"
         style="z-index: 99999;">

        <!-- Toast Success -->
        @if (TempData["Success"] != null)
        {
            <div class="toast align-items-center text-white bg-success border-0 show"
                 role="alert">
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        @TempData["Success"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto"
                            data-bs-dismiss="toast"></button>
                </div>
            </div>
        }

        <!-- Toast Error -->
        @if (TempData["Error"] != null)
        {
            <div class="toast align-items-center text-white bg-danger border-0 show"
                 role="alert">
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="bi bi-exclamation-octagon-fill me-2"></i>
                        @TempData["Error"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto"
                            data-bs-dismiss="toast"></button>
                </div>
            </div>
        }
    </div>


    <!-- 🔥 TOAST MANUAL (EL QUE YA TENÍAS) -->
    <div id="globalToastContainer"
         class="toast-container position-fixed top-0 end-0 p-3"
         style="z-index: 99999;">
        <div id="globalToast" class="toast align-items-center text-bg-danger border-0"
             role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body fw-semibold" id="globalToastMessage"></div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto"
                        data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>


    <!-- Scripts -->
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("scripts", required: false)


    <script>
        // =============================================================
        // 🔥 FUNCIÓN GLOBAL PARA MOSTRAR TOASTS MANUALMENTE
        // =============================================================
        function showToast(message) {
            let toastEl = document.getElementById('globalToast');
            let toastBody = document.getElementById('globalToastMessage');

            toastBody.innerText = message;

            let toast = new bootstrap.Toast(toastEl);
            toast.show();
        }

        // =============================================================
        // 🔥 ACTIVAR AUTOMÁTICAMENTE LOS TOASTS DE TEMPDATA
        // =============================================================
        document.addEventListener("DOMContentLoaded", function () {
            let autoToasts = document.querySelectorAll('.toast.show');
            autoToasts.forEach(t => {
                let toast = new bootstrap.Toast(t, { delay: 3000 });
                toast.show();
            });
        });


        // Lógica sidebar móvil
        const sidebar = document.querySelector('.sidebar');
        const toggleBtn = document.querySelector('.btn-toggle-sidebar');
        const body = document.body;

        if (toggleBtn) {
            toggleBtn.addEventListener('click', () => {
                sidebar.classList.toggle('active');
                body.classList.toggle('sidebar-open');
            });
        }
    </script>

</body>
</html>
