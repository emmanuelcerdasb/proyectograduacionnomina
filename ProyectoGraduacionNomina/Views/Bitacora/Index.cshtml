@model IEnumerable<ProyectoGraduacionNomina.Bitacora>
@using ProyectoGraduacionNomina.Helpers


@{
    ViewBag.Title = "Bitácora";
}

<div class="container mt-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <!-- =========================
         FILTROS
    ========================== -->
    <div class="table-card mb-4">
        <div class="card-header">
            <h3 class="mb-2">Filtros de auditoría</h3>
        </div>

        <div class="p-3">
            @using (Html.BeginForm("Index", "Bitacora", FormMethod.Get))
            {
                <div class="row g-3 align-items-end">

                    <div class="col-md-3">
                        <label class="form-label">Desde</label>
                        <input type="date"
                               name="fechaInicio"
                               value="@Request["fechaInicio"]"
                               class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Hasta</label>
                        <input type="date"
                               name="fechaFin"
                               value="@Request["fechaFin"]"
                               class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Rol</label>
                        @Html.DropDownList(
                            "rol",
                            (SelectList)ViewBag.Roles,
                            "Todos",
                            new { @class = "form-select" }
                        )
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Acción</label>
                        @Html.DropDownList(
                            "accion",
                            (SelectList)ViewBag.Acciones,
                            "Todas",
                            new { @class = "form-select" }
                        )
                    </div>

                    <div class="col-12 text-end mt-2">
                        <button type="submit" class="btn btn-primary-custom">
                            <i class="bi bi-funnel me-1"></i> Filtrar
                        </button>

                        <a href="@Url.Action("Index")" class="btn btn-outline-secondary ms-2">
                            Limpiar
                        </a>
                    </div>
                    <div class="form-footer">
                        <a href="@Url.Action("Index", "Seguridad")" class="btn btn-light cancel-btn">
                            <i class="bi bi-arrow-left-circle me-1"></i> Volver
                        </a>
                    </div>

                </div>
            }
        </div>
    </div>

    <!-- =========================
         TABLA BITÁCORA
    ========================== -->
    <div class="table-card">
        <div class="card-header">
            <h3 class="mb-2">Bitácora del sistema</h3>
            <small class="text-muted">
                Registro de acciones realizadas por los usuarios
            </small>
        </div>

        <div class="d-flex justify-content-between align-items-center px-3 pt-3">
            <small class="text-muted">@ViewBag.TotalRegistros registro(s) — Página @ViewBag.PaginaActual de @ViewBag.TotalPaginas</small>
        </div>
        <table class="table w-100 mt-3">
            <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Usuario</th>
                    <th>Rol</th>
                    <th>Acción</th>
                    <th>Descripción</th>
                    <th>IP</th>
                </tr>
            </thead>

            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            No existen registros para los filtros seleccionados.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
            <tr>
                <td>
                    @item.fecha.ToString("dd/MM/yyyy HH:mm")
                </td>

                <td>
                    @item.Credencial.usuario
                </td>

                <!-- Rol -->
                <td>
                    <span class="badge bg-secondary">
                        @item.Credencial.Rol.nombre
                    </span>
                </td>

                <!-- Acción -->
                <td>
                    <span class="@BitacoraVisualHelper.ObtenerClaseAccion(item.accion)">
                        @item.accion
                    </span>
                </td>


                <td>
                    @item.descripcion
                </td>

                <td class="text-muted">
                    @item.ip_origen
                </td>
            </tr>
                    }
                }
            </tbody>
        </table>

        @{
            int paginaActual  = (int)(ViewBag.PaginaActual ?? 1);
            int totalPaginas  = (int)(ViewBag.TotalPaginas ?? 1);
            string fi  = ViewBag.FechaInicio ?? "";
            string ff  = ViewBag.FechaFin    ?? "";
            string ac  = ViewBag.AccionFiltro ?? "";
            string ro  = ViewBag.RolFiltro    ?? "";

            Func<int, string> pageUrl = p =>
                Url.Action("Index", "Bitacora", new {
                    pagina = p,
                    fechaInicio = fi, fechaFin = ff,
                    accion = ac, rol = ro
                });
        }

        @if (totalPaginas > 1)
        {
            <nav class="d-flex justify-content-center my-3">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                        <a class="page-link" href="@pageUrl(paginaActual - 1)">&#8249;</a>
                    </li>
                    @for (int i = Math.Max(1, paginaActual - 2); i <= Math.Min(totalPaginas, paginaActual + 2); i++)
                    {
                        <li class="page-item @(i == paginaActual ? "active" : "")">
                            <a class="page-link" href="@pageUrl(i)">@i</a>
                        </li>
                    }
                    <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                        <a class="page-link" href="@pageUrl(paginaActual + 1)">&#8250;</a>
                    </li>
                </ul>
            </nav>
        }
    </div>

</div>
