@model ProyectoGraduacionNomina.Departamento

@{
    ViewBag.Title = "Detalles de Departamento";
}

<div class="form-card">
    <div class="form-header">
        <h2><i class="bi bi-eye me-2"></i>Detalles de Departamento</h2>
    </div>

    <div class="form-body">
        <dl class="row">

            <dt class="col-sm-3">Departamento</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.nombre)</dd>

            <dt class="col-sm-3">Descripción</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.descripcion)</dd>
        </dl>
</div>


    <div class="form-footer">
        <a href="@Url.Action("Index")" class="btn btn-light cancel-btn">
            <i class="bi bi-arrow-left-circle me-1"></i> Volver
        </a>

        <div>
            <a href="@Url.Action("Edit", new { id = Model.idDepartamento })" class="btn btn-primary-custom me-1">
                <i class="bi bi-pencil-square me-1"></i> Editar
            </a>
        </div>
    </div>
</div>
