@model ProyectoGraduacionNomina.Departamento

@{
    ViewBag.Title = "Crear Departamento";
}

<div class="form-card">
    <div class="form-header">
        <h2><i class="bi bi-building-add me-2"></i>Crear Departamento</h2>
    </div>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="form-body">
            @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

            <div class="mb-3">
                @Html.LabelFor(model => model.nombre,"Nombre", htmlAttributes: new { @class = "form-label fw-semibold" })
                @Html.EditorFor(model => model.nombre, new { htmlAttributes = new { @class = "form-control modern-input", placeholder = "Ingrese el nombre del departamento" } })
                @Html.ValidationMessageFor(model => model.nombre, "", new { @class = "text-danger small" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(model => model.descripcion,"Descripción", htmlAttributes: new { @class = "form-label fw-semibold" })
                @Html.EditorFor(model => model.descripcion, new { htmlAttributes = new { @class = "form-control modern-input", placeholder = "Ingrese una descripción (opcional)" } })
                @Html.ValidationMessageFor(model => model.descripcion, "", new { @class = "text-danger small" })
            </div>
        </div>

        <div class="form-footer d-flex justify-content-between align-items-center">
            <a href="@Url.Action("Index")" class="btn btn-light cancel-btn">
                <i class="bi bi-arrow-left-circle me-1"></i> Volver
            </a>
            <button type="submit" class="btn btn-primary-custom">
                <i class="bi bi-save2 me-1"></i> Crear
            </button>
        </div>
    }

</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
