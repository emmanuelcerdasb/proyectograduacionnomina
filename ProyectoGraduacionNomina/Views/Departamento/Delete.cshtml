@model ProyectoGraduacionNomina.Departamento

@{
    ViewBag.Title = "Eliminar Departamento";
}

<div class="form-card delete-card">
    <div class="form-header text-danger">
        <h2 class="text-danger"><i class="bi bi-trash me-2"></i>Eliminar Departamento</h2>
    </div>

    <div class="form-body">
        <p class="text-danger">¿Está seguro de eliminar el departamento de <strong>@Model.nombre</strong>?</p>

        <div class="mb-3">
            <label class="form-label fw-semibold text-secondary">Nombre</label>
            <div class="form-control modern-input readonly-field">@Html.DisplayFor(model => model.nombre)</div>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold text-secondary">Descripción</label>
            <div class="form-control modern-input readonly-field">@Html.DisplayFor(model => model.descripcion)</div>
        </div>
    </div>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="form-footer d-flex justify-content-between align-items-center mt-3">
            <a href="@Url.Action("Index")" class="btn btn-light cancel-btn">
                <i class="bi bi-arrow-left-circle me-1"></i> Cancelar
            </a>
            <button type="submit" class="btn btn-danger shadow-sm">
                <i class="bi bi-trash me-1"></i> Eliminar
            </button>
        </div>
    }
</div>
