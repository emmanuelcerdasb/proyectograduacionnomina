@model IEnumerable<ProyectoGraduacionNomina.Vacaciones>

@{
    ViewBag.Title = "Vacaciones";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="table-card">

        <div class="card-header">
            <h3 class="mb-1">
                <i class="bi bi-sun me-2"></i>
                Solicitudes de Vacaciones
            </h3>
            <small class="text-muted">Gestione las solicitudes de vacaciones del personal</small>
        </div>

        <div class="p-3">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-circle me-1"></i> @TempData["Error"]
                </div>
            }

            <div class="d-flex justify-content-end mb-3">
                <a href="@Url.Action("Solicitar", "Vacaciones")" class="btn btn-primary-custom">
                    <i class="bi bi-plus-circle me-1"></i> Nueva solicitud
                </a>
            </div>

            @if (!Model.Any())
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-1"></i>
                    No hay solicitudes de vacaciones registradas.
                </div>
            }
            else
            {
                <table class="table w-100">
                    <thead>
                        <tr>
                            <th>Empleado</th>
                            <th>Fecha inicio</th>
                            <th>Fecha fin</th>
                            <th class="text-center">Dias habiles</th>
                            <th class="text-center">Estado</th>
                            <th>Solicitud</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var vac in Model)
                        {
                            <tr>
                                <td>@vac.Empleado.Persona.nombre @vac.Empleado.Persona.apellido1 @vac.Empleado.Persona.apellido2</td>
                                <td>@vac.fecha_inicio.ToString("dd/MM/yyyy")</td>
                                <td>@vac.fecha_fin.ToString("dd/MM/yyyy")</td>
                                <td class="text-center">
                                    <span class="badge bg-primary">@vac.dias_habiles</span>
                                </td>
                                <td class="text-center">
                                    @if (vac.estado == "Aprobado")
                                    {
                                        <span class="badge bg-success">@vac.estado</span>
                                    }
                                    else if (vac.estado == "Rechazado")
                                    {
                                        <span class="badge bg-danger">@vac.estado</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">@vac.estado</span>
                                    }
                                </td>
                                <td><small class="text-muted">@vac.fecha_solicitud.ToString("dd/MM/yyyy HH:mm")</small></td>
                                <td>
                                    <a href="@Url.Action("Detalle", "Vacaciones", new { id = vac.idVacaciones })"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye me-1"></i> Ver
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

        </div>
    </div>
</div>
