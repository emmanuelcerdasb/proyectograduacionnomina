@{
    ViewBag.Title = "Solicitar Vacaciones";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="table-card">

        <div class="card-header">
            <h3 class="mb-1">
                <i class="bi bi-plus-circle me-2"></i>
                Nueva Solicitud de Vacaciones
            </h3>
            <small class="text-muted">Registre el periodo de vacaciones para el empleado</small>
        </div>

        <div class="p-4">

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-circle me-1"></i> @TempData["Error"]
                </div>
            }

            @using (Html.BeginForm("Solicitar", "Vacaciones", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                <div class="row g-3">

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Empleado</label>
                        @Html.DropDownList("empleadoId",
                            ViewBag.EmpleadoId as IEnumerable<SelectListItem>,
                            "-- Seleccione un empleado --",
                            new { @class = "form-select" })
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Fecha inicio</label>
                        <input type="date" name="fechaInicio" class="form-control"
                               value="@ViewBag.FechaHoy" required
                               onchange="calcularDias()" id="fechaInicio" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Fecha fin</label>
                        <input type="date" name="fechaFin" class="form-control"
                               value="@ViewBag.FechaHoy" required
                               onchange="calcularDias()" id="fechaFin" />
                    </div>

                    <div class="col-md-12">
                        <label class="form-label fw-semibold">Observaciones</label>
                        <input type="text" name="observaciones" class="form-control"
                               placeholder="Motivo u observaciones" maxlength="500" />
                    </div>

                    <div class="col-md-12">
                        <div class="alert alert-info mb-0" id="infoDias">
                            <i class="bi bi-info-circle me-1"></i>
                            Seleccione las fechas para ver los dias habiles calculados.
                        </div>
                    </div>

                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary-custom">
                        <i class="bi bi-floppy me-1"></i> Registrar solicitud
                    </button>
                    <a href="@Url.Action("Index", "Vacaciones")" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Volver
                    </a>
                </div>
            }

        </div>
    </div>
</div>

<script>
    function calcularDias() {
        var ini = document.getElementById('fechaInicio').value;
        var fin = document.getElementById('fechaFin').value;
        if (!ini || !fin) return;
        var d1 = new Date(ini), d2 = new Date(fin);
        if (d2 < d1) { document.getElementById('infoDias').innerHTML = '<i class="bi bi-exclamation-triangle me-1"></i> La fecha de fin debe ser mayor o igual a la de inicio.'; return; }
        var dias = 0;
        for (var d = new Date(d1); d <= d2; d.setDate(d.getDate() + 1)) {
            var dow = d.getDay();
            if (dow !== 0 && dow !== 6) dias++;
        }
        document.getElementById('infoDias').innerHTML = '<i class="bi bi-calendar-check me-1"></i> <strong>' + dias + ' dias habiles</strong> del ' + d1.toLocaleDateString('es-CR') + ' al ' + d2.toLocaleDateString('es-CR');
    }
    calcularDias();
</script>
