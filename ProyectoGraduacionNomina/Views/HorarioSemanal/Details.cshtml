@model ProyectoGraduacionNomina.HorarioSemanal

@{
    ViewBag.Title = "Detalle del Horario Semanal";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <!-- ===============================
         CARD PRINCIPAL
         =============================== -->
    <div class="table-card">

        <div class="card-header">
            <h3 class="mb-2">
                <i class="bi bi-calendar-week me-1"></i>
                Detalle del Horario Semanal
            </h3>
            <small class="text-muted">
                Configuración semanal de días y horas
            </small>
        </div>

        <div class="p-3">

            <!-- ===============================
                 INFO GENERAL
                 =============================== -->
            <div class="row mb-3">
                <div class="col-md-4">
                    <strong>Nombre:</strong><br />
                    @Model.nombre
                </div>
                <div class="col-md-4">
                    <strong>Jornada:</strong><br />
                    @(Model.Jornada != null ? Model.Jornada.nombre : "No asignada")
                </div>
                <div class="col-md-4">
                    <strong>Fecha creación:</strong><br />
                    @Model.fecha_creacion.ToString("dd/MM/yyyy")
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.descripcion))
            {
                <div class="mb-3">
                    <strong>Descripción:</strong><br />
                    <span class="text-muted">@Model.descripcion</span>
                </div>
            }

            <hr />

            <!-- ===============================
                 DÍAS DEL HORARIO
                 =============================== -->
            <div class="d-flex justify-content-between align-items-center mb-3 mt-5">
                <h3 class="mb-0 text-primary">
                    <i class="bi bi-clock me-1"></i>
                    Días del Horario
                </h3>

                

                <!-- Reutiliza Horario/Create -->
                <a href="@Url.Action("Create", "Horario", new { horarioSemanalId = Model.idHorarioSemanal })"
                   class="btn btn-primary-custom btn-sm">
                    <i class="bi bi-plus-circle me-1"></i>
                    Agregar día
                </a>
            </div>

            <table class="table w-100">
                <thead>
                    <tr>
                        <th>Día</th>
                        <th>Hora inicio</th>
                        <th>Hora fin</th>
                        <th class="text-center">Operaciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Horario != null && Model.Horario.Any())
                    {
                        foreach (var dia in Model.Horario)
                        {
                            <tr>
                                <td>@dia.dia_semana</td>
                                <td>@dia.hora_inicio</td>
                                <td>@dia.hora_fin</td>
                                <td class="text-center">
                                    @{
                                        ViewBag.RowId = dia.idHorario;
                                        ViewBag.ControllerName = "Horario";
                                    }
                                    @Html.Partial("_RowActions")
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted">
                                No hay días configurados para este horario semanal
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- ===============================
                 FOOTER
                 =============================== -->
            <div class="form-footer">
                <a href="@Url.Action("Index")" class="btn btn-light cancel-btn">
                    <i class="bi bi-arrow-left-circle me-1"></i>
                    Volver
                </a>
            </div>

        </div>
    </div>
</div>
