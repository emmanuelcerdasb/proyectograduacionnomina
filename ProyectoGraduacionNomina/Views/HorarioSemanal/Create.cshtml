@model ProyectoGraduacionNomina.HorarioSemanal

@{
    ViewBag.Title = "Crear Horario Semanal";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <div class="table-card">

        <div class="card-header">
            <h3 class="mb-1">
                <i class="bi bi-plus-circle me-1"></i>
                Nuevo Horario Semanal
            </h3>
            <small class="text-muted">
                Define la estructura semanal base
            </small>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            <div class="p-3">

                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <div class="row mb-3">
                    <div class="col-md-6">
                        @Html.LabelFor(m => m.nombre, "Nombre Del Horario Semanal")
                        @Html.EditorFor(m => m.nombre, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(m => m.nombre)
                    </div>

                    <div class="col-md-6">
                        @Html.LabelFor(m => m.Jornada_idJornada, "Jornada")
                        @Html.DropDownList("Jornada_idJornada", null, "-- Seleccione --",
                            new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Jornada_idJornada)
                    </div>
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.descripcion, "Descripción")
                    @Html.TextAreaFor(m => m.descripcion,
                        new { @class = "form-control", placeholder = "Opcional" })
                </div>

                <div class="form-footer">
                    <a href="@Url.Action("Index")" class="btn btn-light cancel-btn">
                        <i class="bi bi-arrow-left-circle me-1"></i> Volver
                    </a>
 
                    
                    <button type="submit" class="btn btn-primary-custom">
                        <i class="bi bi-check-circle me-1"></i>
                        Guardar
                    </button>
                </div>
            </div>
        }
    </div>
</div>
