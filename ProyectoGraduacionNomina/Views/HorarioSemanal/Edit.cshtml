@model ProyectoGraduacionNomina.HorarioSemanal

@{
    ViewBag.Title = "Editar Horario Semanal";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <div class="table-card">

        <div class="card-header">
            <h3 class="mb-1">
                <i class="bi bi-pencil-square me-1"></i>
                Editar Horario Semanal
            </h3>
            <small class="text-muted">
                Modifique la información general
            </small>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.idHorarioSemanal)

    <div class="p-3">

        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="row mb-3">
            <div class="col-md-6">
                @Html.LabelFor(m => m.nombre)
                @Html.EditorFor(m => m.nombre, new { htmlAttributes = new { @class = "form-control" } })
            </div>

            <div class="col-md-6">
                @Html.LabelFor(m => m.Jornada_idJornada, "Jornada")
                @Html.DropDownList("Jornada_idJornada", null,
                    new { @class = "form-control" })
            </div>
        </div>

        <div class="mb-3">
            @Html.LabelFor(m => m.descripcion)
            @Html.TextAreaFor(m => m.descripcion,
                new { @class = "form-control" })
        </div>

        <div class="form-footer">
            <a href="@Url.Action("Index")" class="btn btn-light cancel-btn">
                <i class="bi bi-arrow-left-circle me-1"></i> Volver
            </a>

            <a href="@Url.Action("Details", new { id = Model.idHorarioSemanal })" class="btn btn-primary-custom">
                <i class="bi bi-calendar-week me-1"></i> Ir a "Crear los Días de este Horario Semanal"
            </a>
            <button type="submit" class="btn btn-primary-custom">
                <i class="bi bi-check-circle me-1"></i>
                  Guardar: Edición del Horario Semanal
            </button>
        </div>
    </div>
        }
    </div>
</div>
