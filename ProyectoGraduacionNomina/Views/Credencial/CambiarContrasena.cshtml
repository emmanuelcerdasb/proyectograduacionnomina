@{
    ViewBag.Title = "Cambiar Contraseña";
}

<div class="form-card">
    <div class="form-header">
        <h2><i class="bi bi-shield-lock me-2"></i>Cambiar Contraseña</h2>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="form-body">
            <div class="mb-3">
                <label class="form-label fw-semibold">Contraseña actual</label>
                <input type="password" name="contrasenaActual" class="form-control modern-input" required />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Nueva contraseña</label>
                <input type="password" name="nuevaContrasena" class="form-control modern-input" required />
            </div>
        </div>

        <div class="form-footer">
            <button type="submit" class="btn btn-primary-custom">
                Actualizar
            </button>
        </div>
    }
</div>
