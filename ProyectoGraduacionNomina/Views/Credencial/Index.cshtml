@model IEnumerable<ProyectoGraduacionNomina.Credencial>

@{
    ViewBag.Title = "Credenciales";
}

<div class="container mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    else if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">@TempData["Mensaje"]</div>
    }
    else if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

<div class="table-card">
    <div class="card-header">
        <h3 class="mb-2">Listado de Credenciales</h3>

        <div class="d-flex justify-content-end">
            <a href="@Url.Action("Create")" class="btn btn-primary-custom">
                <i class="bi bi-plus-circle me-1"></i> Nuevo Credenciales
            </a>
        </div>
    </div>

    <table class="table w-100 mt-3">
        <thead>
            <tr>
                <th>Usuario</th>
                <th>Rol</th>
                <th>Activo</th>
                <th>Fecha Creación</th>
                <th>Último Cambio</th>
                <th class="text-center">Operaciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.usuario</td>
                    <td>@item.Rol.nombre</td>
                    <td>@(item.activo ? "Sí" : "No")</td>
                    <td>@item.fecha_creacion.ToShortDateString()</td>
                    <td>
                        @Html.Raw(item.fecha_ultimo_cambio.HasValue
                        ? item.fecha_ultimo_cambio.Value.ToString("dd/MM/yyyy")
                        : "<span class='text-gray-400'>Sin cambios</span>")
                    </td>



                    <td class="text-center">
                        @{
                            ViewBag.RowId = item.idCredencial;
                            ViewBag.ControllerName = "Credencial";
                        }

                        @Html.Partial("_RowActions")

                        <!-- Resetear contraseña (POST seguro con AntiForgeryToken) -->
                        @using (Html.BeginForm("ResetPassword", "Credencial", new { id = item.idCredencial }, FormMethod.Post, new { style = "display:inline" }))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit"
                                    class="btn btn-sm btn-secondary icon-btn"
                                    title="Resetear contraseña"
                                    onclick="return confirm('¿Resetear contraseña de @item.usuario a la contraseña temporal?')">
                                <i class="bi bi-key"></i>
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="form-footer">
        <a href="@Url.Action("Index", "Mantenimiento")" class="btn btn-light cancel-btn">
            <i class="bi bi-arrow-left-circle me-1"></i> Volver
        </a>
    </div>
</div>
</div>
