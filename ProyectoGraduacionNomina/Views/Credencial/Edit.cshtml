@model ProyectoGraduacionNomina.Credencial

@{
    ViewBag.Title = "Editar Credencial";
}

<div class="form-card">
    <div class="form-header">
        <h2><i class="bi bi-pencil-square me-2"></i>Editar Credencial</h2>
    </div>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.idCredencial)

        <div class="form-body">
            @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

            <div class="mb-3">
                @Html.LabelFor(m => m.usuario,"Usuario", new { @class = "form-label fw-semibold" })
                @Html.EditorFor(m => m.usuario, new { htmlAttributes = new { @class = "form-control modern-input" } })
                @Html.ValidationMessageFor(m => m.usuario, "", new { @class = "text-danger small" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(m => m.contrasena,"Contraseña", new { @class = "form-label fw-semibold" })
                @Html.PasswordFor(m => m.contrasena, new { @class = "form-control modern-input", placeholder = "Nueva contraseña (opcional)" })
                @Html.ValidationMessageFor(m => m.contrasena, "", new { @class = "text-danger small" })
            </div>

            <div class="mb-3">
                @Html.Label("Rol", new { @class = "form-label fw-semibold" })
                @Html.DropDownList("Rol_idRol", null, "-- Seleccione un rol --", new { @class = "form-select modern-input" })
            </div>

            <div class="form-check mb-3">
                @Html.CheckBoxFor(m => m.activo, new { @class = "form-check-input" })
                @Html.LabelFor(m => m.activo, new { @class = "form-check-label" })
            </div>
        </div>

        <div class="form-footer">
            <a href="@Url.Action("Index")" class="btn btn-light cancel-btn">
                <i class="bi bi-arrow-left-circle me-1"></i> Volver
            </a>
            <button type="submit" class="btn btn-primary-custom">
                <i class="bi bi-save2 me-1"></i> Guardar cambios
            </button>
        </div>
    }
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
