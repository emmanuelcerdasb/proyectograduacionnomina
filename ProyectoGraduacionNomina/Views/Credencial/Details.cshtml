@model ProyectoGraduacionNomina.Credencial

@{
    ViewBag.Title = "Detalles de Credencial";
}

<div class="form-card">
    <div class="form-header">
        <h2><i class="bi bi-eye me-2"></i>Detalles de Credencial</h2>
    </div>

    <div class="form-body">
        <dl class="row">
            <dt class="col-sm-3">Usuario</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.usuario)</dd>

            <dt class="col-sm-3">Rol</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Rol.nombre)</dd>

            <dt class="col-sm-3">Activo</dt>
            <dd class="col-sm-9">@(Model.activo ? "Sí" : "No")</dd>

            <dt class="col-sm-3">Fecha creación</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.fecha_creacion)</dd>

            <dt class="col-sm-3">Último cambio</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.fecha_ultimo_cambio)</dd>
        </dl>
    </div>

    <div class="form-footer">
        <a href="@Url.Action("Index")" class="btn btn-light cancel-btn">
            <i class="bi bi-arrow-left-circle me-1"></i> Volver
        </a>

        <div>
            <a href="@Url.Action("CambiarContrasena", new { id = Model.idCredencial })" class="btn btn-secondary me-1 icon-btn">
                <i class="bi bi-key"></i> Cambiar contraseña
            </a>

            <a href="@Url.Action("Edit", new { id = Model.idCredencial })" class="btn btn-primary-custom me-1">
                <i class="bi bi-pencil-square me-1"></i> Editar
            </a>
        </div>
    </div>

</div>
