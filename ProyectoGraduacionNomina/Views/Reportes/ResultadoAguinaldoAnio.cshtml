@model IEnumerable<ProyectoGraduacionNomina.Aguinaldo>

@{
    ViewBag.Title = "Reporte Aguinaldo";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var lista = Model.ToList();
}

<div class="container mt-4">
    <div class="table-card">
        <div class="card-header">
            <h3 class="mb-0"><i class="bi bi-gift me-2"></i>Aguinaldo @ViewBag.Anio</h3>
            <small class="text-muted">@lista.Count empleado(s) &nbsp;|&nbsp; Fecha maxima de pago: 20 de diciembre @ViewBag.Anio</small>
        </div>
        <div class="p-3">

            @if (!lista.Any())
            {
                <div class="alert alert-info">No hay aguinaldos registrados para @ViewBag.Anio.</div>
            }
            else
            {
                <table class="table w-100">
                    <thead>
                        <tr>
                            <th>Empleado</th>
                            <th>Cedula</th>
                            <th>Puesto</th>
                            <th class="text-end">Monto aguinaldo</th>
                            <th class="text-center">Estado</th>
                            <th>Fecha calculo</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in lista)
                        {
                            <tr>
                                <td>@a.Empleado.Persona.nombre @a.Empleado.Persona.apellido1 @a.Empleado.Persona.apellido2</td>
                                <td>@a.Empleado.Persona.cedula</td>
                                <td><small>@a.Empleado.Puesto.nombre</small></td>
                                <td class="text-end fw-bold">&#x20A1;@a.monto.ToString("N2")</td>
                                <td class="text-center"><span class="badge bg-secondary">@a.estado</span></td>
                                <td><small>@a.fecha_calculo.ToString("dd/MM/yyyy")</small></td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <th colspan="3">TOTAL A PAGAR</th>
                            <th class="text-end fw-bold">&#x20A1;@lista.Sum(a => a.monto).ToString("N2")</th>
                            <th colspan="2"></th>
                        </tr>
                    </tfoot>
                </table>
            }

            <a href="@Url.Action("AguinaldoAnio","Reportes")" class="btn btn-outline-secondary mt-2">
                <i class="bi bi-arrow-left me-1"></i> Nuevo reporte
            </a>
        </div>
    </div>
</div>
