@{
    ViewBag.Title = "Reporte de Aguinaldo por Anio";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="table-card">
        <div class="card-header">
            <h3 class="mb-1"><i class="bi bi-gift me-2"></i>Reporte de Aguinaldo por Anio</h3>
            <small class="text-muted">Consolida todos los aguinaldos calculados en un anio</small>
        </div>
        <div class="p-4">

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger"><i class="bi bi-exclamation-circle me-1"></i> @TempData["Error"]</div>
            }

            @using (Html.BeginForm("AguinaldoAnio", "Reportes", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <div class="row g-3">
                    <div class="col-md-2">
                        <label class="form-label fw-semibold">Anio</label>
                        <input type="number" name="anio" class="form-control"
                               value="@ViewBag.AnioActual" min="2020" max="2099" required />
                    </div>
                    <div class="col-md-3 d-flex align-items-end gap-2">
                        <button type="submit" class="btn btn-primary-custom">
                            <i class="bi bi-search me-1"></i> Generar
                        </button>
                        <a href="@Url.Action("Index","Reportes")" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Volver
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
