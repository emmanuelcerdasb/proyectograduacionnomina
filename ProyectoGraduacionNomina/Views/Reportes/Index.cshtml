@{
    ViewBag.Title = "Reportes";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-3">
    <div class="row mb-3">
        <div class="col-12">
            <h3 class="mb-0">Reportes</h3>
            <small class="text-muted">Seleccione el tipo de reporte</small>
        </div>
    </div>

    <div class="row g-3">

        <!-- Reporte Asistencia por Empleado -->
        <div class="col-md-4">
            <a href="@Url.Action("AsistenciaEmpleado","Reportes")"
               class="card p-3 h-100 text-decoration-none text-reset">
                <div class="d-flex align-items-center">
                    <div class="me-3 rounded-3 p-3" style="background:#EFF6FF">
                        <i class="bi bi-calendar-check" style="font-size:1.4rem; color:#1D4ED8"></i>
                    </div>
                    <div>
                        <h5 class="mb-0">Asistencia por empleado</h5>
                        <small class="text-muted">Rango de fechas</small>
                    </div>
                </div>
            </a>
        </div>

        <!-- Resumen Mensual -->
        <div class="col-md-4">
            <a href="@Url.Action("ResumenAsistenciaMensual","Reportes")"
               class="card p-3 h-100 text-decoration-none text-reset">
                <div class="d-flex align-items-center">
                    <div class="me-3 rounded-3 p-3" style="background:#ECFDF5">
                        <i class="bi bi-bar-chart" style="font-size:1.4rem; color:#16A34A"></i>
                    </div>
                    <div>
                        <h5 class="mb-0">Resumen mensual</h5>
                        <small class="text-muted">Indicadores de asistencia</small>
                    </div>
                </div>
            </a>
        </div>

        <!-- Nomina por periodo -->
        <div class="col-md-4">
            <a href="@Url.Action("NominaPeriodo","Reportes")"
               class="card p-3 h-100 text-decoration-none text-reset">
                <div class="d-flex align-items-center">
                    <div class="me-3 rounded-3 p-3" style="background:#FFF7ED">
                        <i class="bi bi-receipt" style="font-size:1.4rem; color:#EA580C"></i>
                    </div>
                    <div>
                        <h5 class="mb-0">Nomina por periodo</h5>
                        <small class="text-muted">Todos los empleados de un mes/anio</small>
                    </div>
                </div>
            </a>
        </div>

        <!-- Aguinaldo por anio -->
        <div class="col-md-4">
            <a href="@Url.Action("AguinaldoAnio","Reportes")"
               class="card p-3 h-100 text-decoration-none text-reset">
                <div class="d-flex align-items-center">
                    <div class="me-3 rounded-3 p-3" style="background:#FEF9C3">
                        <i class="bi bi-gift" style="font-size:1.4rem; color:#CA8A04"></i>
                    </div>
                    <div>
                        <h5 class="mb-0">Aguinaldo por anio</h5>
                        <small class="text-muted">Consolidado de aguinaldos calculados</small>
                    </div>
                </div>
            </a>
        </div>

    </div>
</div>
