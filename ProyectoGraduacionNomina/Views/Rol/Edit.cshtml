@model ProyectoGraduacionNomina.Rol

@{
    ViewBag.Title = "Editar Rol";
}

<div class="form-card">
    <div class="form-header">
        <h2><i class="bi bi-pencil-square me-2"></i>Editar Rol</h2>
    </div>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.idRol)

        <div class="form-body">
            @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

            <div class="mb-3">
                @Html.LabelFor(m => m.nombre,"Nombre", new { @class = "form-label fw-semibold" })
                @Html.EditorFor(m => m.nombre, new { htmlAttributes = new { @class = "form-control modern-input" } })
                @Html.ValidationMessageFor(m => m.nombre, "", new { @class = "text-danger small" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(m => m.descripcion,"Descripción", new { @class = "form-label fw-semibold" })
                @Html.TextAreaFor(m => m.descripcion, new { @class = "form-control modern-input", rows = 3 })
                @Html.ValidationMessageFor(m => m.descripcion, "", new { @class = "text-danger small" })
            </div>
        </div>

        <div class="form-footer">
            <a href="@Url.Action("Index")" class="btn btn-light cancel-btn">
                <i class="bi bi-arrow-left-circle me-1"></i> Volver
            </a>
            <button type="submit" class="btn btn-primary-custom">
                <i class="bi bi-save2 me-1"></i> Guardar cambios
            </button>
        </div>
    }
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
