@model ProyectoGraduacionNomina.Rol

@{
    ViewBag.Title = "Detalles Rol";
}

<div class="form-card">
    <div class="form-header">
        <h2><i class="bi bi-info-circle me-2"></i>Detalles del Rol</h2>
    </div>

    <div class="form-body">
        <dl class="row">
            <dt class="col-sm-3">Nombre</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.nombre)</dd>

            <dt class="col-sm-3">Descripción</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.descripcion)</dd>
        </dl>
    </div>

    <div class="form-footer">
        <a href="@Url.Action("Index")" class="btn btn-light cancel-btn">
            <i class="bi bi-arrow-left-circle me-1"></i> Volver
        </a>
    </div>
</div>
