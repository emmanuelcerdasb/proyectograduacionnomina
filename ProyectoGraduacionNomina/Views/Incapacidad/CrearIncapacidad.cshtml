@model Incapacidad

@{
    ViewBag.Title = "Registrar Incapacidad";
}

<div class="container mt-4">

    <div class="form-card">
        <div class="form-header">
            <h2>
                <i class="bi bi-plus-circle me-2"></i>
                Registrar Incapacidad
            </h2>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            <div class="form-body">

                @if (User.IsInRole("Administrador") || User.IsInRole("Jefe") || User.IsInRole("Jefa") || User.IsInRole("RRHH"))
                {
                    <div class="mb-3">
                        <label class="form-label">Empleado</label>
                        @Html.DropDownList("Empleado_idEmpleado", null, "-- Seleccione --",
                            new { @class = "form-control modern-input" })
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label">Tipo de Incapacidad</label>
                    @Html.DropDownList("TipoIncapacidad_idTipoIncapacidad", null, "-- Seleccione --",
                        new { @class = "form-control modern-input" })
                </div>

                <div class="mb-3">
                    <label class="form-label">
                        Entidad emisora
                        <small class="text-muted">(Ej: CCSS, INS, Médico privado)</small>
                    </label>
                    @Html.TextBoxFor(m => m.entidad,
                        new { @class = "form-control modern-input", required = "required" })
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Fecha inicio</label>
                        @Html.TextBoxFor(m => m.fecha_inicio,
                            new
                            {
                                @class = "form-control modern-input",
                                type = "date",
                                min = ViewBag.FechaMin
                            })
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Fecha fin</label>
                        @Html.TextBoxFor(m => m.fecha_fin,
                            new { @class = "form-control modern-input", type = "date", min = ViewBag.FechaMin})
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">
                        Porcentaje de pago
                        <small class="text-muted">(Ejemplo: 0.60 = 60%)</small>
                    </label>

                    @Html.TextBoxFor(m => m.porcentaje_pago,
                        new
                        {
                            @class = "form-control modern-input",
                            type = "number",
                            step = "0.01",
                            min = "0",
                            max = "1",
                            required = "required",
                            placeholder = "Ej: 0.60"
                        })

                </div>

                <div class="mb-3">
                    <label class="form-label">Descripción</label>
                    @Html.TextAreaFor(m => m.descripcion,
                        new { @class = "form-control modern-input", rows = 3 })
                </div>
            </div>

            <div class="form-footer">
                <a href="@Url.Action("Index")"
                   class="btn btn-light cancel-btn">
                    <i class="bi bi-arrow-left-circle me-1"></i> Volver
                </a>

                <button type="submit" class="btn btn-primary-custom">
                    <i class="bi bi-save me-1"></i> Guardar
                </button>
            </div>
        }
    </div>
</div>
