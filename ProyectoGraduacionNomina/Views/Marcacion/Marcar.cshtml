@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Marcar Entrada / Salida";
}

<div class="form-card mt-4 text-center" style="max-width:700px;margin:0 auto;">
    <div class="form-header">
        <h2><i class="bi bi-clock-history me-2"></i>Marcación</h2>
    </div>

    @using (Html.BeginForm("MarcarEntradaSalida", "Marcacion", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

<div class="form-body">

    <!-- RELOJ GRANDE -->
    <h1 id="clockDisplay" class="fw-bold" style="font-size:55px;"></h1>
    <h4 id="dateDisplay" class="text-muted mb-4"></h4>

    <!-- Empleado autenticado -->
    <div class="mb-3">
        <label class="fw-semibold">Colaborador</label>
        <input type="text" class="form-control modern-input" readonly
               value="@ViewBag.NombreEmpleado" />
        <input type="hidden" name="Empleado_idEmpleado" value="@ViewBag.Empleado_idEmpleado" />
    </div>

    <!-- Observación opcional -->




    <div class="mb-3">
        <label class="fw-semibold">Observación (opcional)</label>
        <textarea name="observacion" class="form-control modern-input" rows="2"
                  placeholder="Escriba una nota si es necesario..."></textarea>
    </div>

    <!-- BOTONES ENTRADA / SALIDA -->
    <div class="d-flex justify-content-center gap-3 mt-3">

        <button name="tipo" value="Entrada"
                class="btn btn-success px-4 py-2"
                id="btnEntrada"
                @(ViewBag.HabilitarEntrada ? "" : "disabled")>
            <i class="bi bi-box-arrow-in-right me-1"></i> Entrada
        </button>

        <button name="tipo" value="Salida"
                class="btn btn-danger px-4 py-2"
                id="btnSalida"
                @(ViewBag.HabilitarSalida ? "" : "disabled")>
            <i class="bi bi-box-arrow-left me-1"></i> Salida
        </button>

    </div>

    <div class="mt-3 text-muted small">
        <em>La hora se registrará automáticamente al presionar Entrada o Salida.</em>
    </div>

</div>
    }
</div>

@section Scripts {
    <script>
        function updateClock() {
            const now = new Date();

            document.getElementById("clockDisplay").innerText =
                now.toLocaleTimeString("es-CR", { hour: "2-digit", minute: "2-digit", second: "2-digit" });

            document.getElementById("dateDisplay").innerText =
                now.toLocaleDateString("es-CR", {
                    weekday: "long",
                    year: "numeric",
                    month: "long",
                    day: "numeric"
                });
        }

        setInterval(updateClock, 1000);
        updateClock();
    </script>
}
