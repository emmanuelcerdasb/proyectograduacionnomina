@model IEnumerable<ProyectoGraduacionNomina.SesionUsuario>

@{
    ViewBag.Title = "Sesiones Activas";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0"><i class="bi bi-people-fill me-2"></i>Sesiones Activas</h3>
            <small class="text-muted">Usuarios conectados actualmente al sistema</small>
        </div>
        <a href="@Url.Action("Index","Seguridad")" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Volver
        </a>
    </div>

    <div class="table-card">
        @if (!Model.Any())
        {
            <div class="alert alert-info m-3">No hay sesiones activas en este momento.</div>
        }
        else
        {
            <table class="table w-100 mb-0">
                <thead>
                    <tr>
                        <th>Usuario</th>
                        <th>Rol</th>
                        <th>IP</th>
                        <th>Dispositivo</th>
                        <th>Inicio de sesión</th>
                        <th class="text-center">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td><i class="bi bi-person-circle me-1 text-secondary"></i>@s.Credencial.usuario</td>
                            <td><span class="badge bg-primary">@s.Credencial.Rol.nombre</span></td>
                            <td><code>@s.ip</code></td>
                            <td>@s.dispositivo</td>
                            <td>@s.fecha_inicio.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-center">
                                @using (Html.BeginForm("CerrarSesion", "Seguridad", new { id = s.idSesion }, FormMethod.Post))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger"
                                            onclick="return confirm('¿Cerrar esta sesión?')">
                                        <i class="bi bi-box-arrow-right me-1"></i>Cerrar
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
