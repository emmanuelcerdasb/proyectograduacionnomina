@model Permiso

@{
    ViewBag.Title = "Solicitar Permiso";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <div class="table-card">

        <!-- ================= HEADER ================= -->
        <div class="form-header">
            <h3>
                <i class="bi bi-plus-circle me-2"></i>
                Nueva Solicitud de Permiso
            </h3>
            <small class="text-muted">
                Complete la información requerida para solicitar su permiso.
            </small>
        </div>

        <!-- ================= FORM ================= -->
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

    <div class="row mt-3">

        <!-- Tipo Permiso -->
        <div class="col-md-6 mb-3">
            <label class="form-label fw-semibold">
                Tipo de Permiso
            </label>
            @Html.DropDownListFor(
                m => m.TipoPermiso_idTipoPermiso,
                (IEnumerable<SelectListItem>)ViewBag.TipoPermiso_idTipoPermiso,
                "-- Seleccione --",
                new { @class = "form-select", required = "required" }
            )
        </div>

        @{
            var hoy = DateTime.Now.ToString("yyyy-MM-dd");
        }

        <!-- Fecha Inicio -->
        <div class="col-md-3 mb-3">
            <label class="form-label fw-semibold">
                Fecha Inicio
            </label>
            @Html.TextBoxFor(
                m => m.fecha_inicio,
                new
                {
                    @class = "form-control",
                    type = "date",
                    min = hoy,
                    required = "required"
                }
            )
        </div>

        <!-- Fecha Fin -->
        <div class="col-md-3 mb-3">
            <label class="form-label fw-semibold">
                Fecha Fin
            </label>
            @Html.TextBoxFor(
                m => m.fecha_fin,
                new
                {
                    @class = "form-control",
                    type = "date",
                    min = hoy,
                    required = "required"
                }
            )
        </div>


    </div>

            <!-- Motivo -->
            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Motivo del Permiso
                </label>
                @Html.TextAreaFor(
                    m => m.motivo,
                    new
                    {
                        @class = "form-control",
                        rows = 3,
                        placeholder = "Describa el motivo del permiso",
                        required = "required"
                    }
                )
            </div>

            <!-- ================= FOOTER ================= -->
            <div class="form-footer">
                <a href="@Url.Action("Index")"
                   class="btn btn-light cancel-btn">
                    <i class="bi bi-arrow-left-circle me-1"></i> Volver
                </a>

                <button type="submit" class="btn btn-primary-custom ms-2">
                    <i class="bi bi-send me-1"></i> Enviar Solicitud
                </button>
            </div>
        }

    </div>

</div>
