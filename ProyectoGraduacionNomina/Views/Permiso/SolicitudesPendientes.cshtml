@model IEnumerable<Permiso>

@{
    ViewBag.Title = "Permisos Pendientes";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <div class="table-card">
        <div class="card-header">
            <h3 class="mb-1">
                <i class="bi bi-person-check me-2"></i>
                Solicitudes de Permiso Pendientes
            </h3>
            <small class="text-muted">
                Aprobación o rechazo de permisos solicitados
            </small>
        </div>

        <table class="table w-100 mt-3">
            <thead>
                <tr>
                    <th>Empleado</th>
                    <th>Tipo Permiso</th>
                    <th>Desde</th>
                    <th>Hasta</th>
                    <th>Motivo</th>
                    <th>Estado</th>
                    <th class="text-center">Operaciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted">
                            No hay solicitudes pendientes.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @item.Empleado.Persona.nombre
                                @item.Empleado.Persona.apellido1
                                @item.Empleado.Persona.apellido2
                                <br />
                                <small class="text-muted">
                                    @item.Empleado.Persona.cedula
                                </small>
                            </td>

                            <td>
                                @item.TipoPermiso.nombre
                                <br />
                                <small class="text-muted">
                                    @{
                                        if (item.TipoPermiso.es_administrativo)
                                        {
                                            @:Administrativo
                                        }
                                        else if (item.TipoPermiso.tiene_goce)
                                        {
                                            @:Con goce de salario
                                        }
                                        else
                                        {
                                            @:Sin goce de salario
                                        }
                                    }
                                </small>
                            </td>

                            <td>@item.fecha_inicio.ToShortDateString()</td>
                            <td>@item.fecha_fin.ToShortDateString()</td>
                            <td>@item.motivo</td>

                            <td>
                                <span class="badge bg-warning text-dark">
                                    @item.estado
                                </span>
                            </td>

                            <td class="text-center">
                                <div class="row-actions">

                                    @using (Html.BeginForm("Aprobar", "Permiso", new { id = item.idPermiso }, FormMethod.Post))
                                    {
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="icon-btn btn-info"
                                                title="Aprobar permiso">
                                            <i class="bi bi-check-circle"></i>
                                        </button>
                                    }

                                    @using (Html.BeginForm("Rechazar", "Permiso", new { id = item.idPermiso }, FormMethod.Post))
                                    {
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="icon-btn btn-danger"
                                                title="Rechazar permiso">
                                            <i class="bi bi-x-circle"></i>
                                        </button>
                                    }

                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        <div class="form-footer">
            <a href="@Url.Action("Index")" class="btn btn-light cancel-btn">
                <i class="bi bi-arrow-left-circle me-1"></i> Volver
            </a>
        </div>
    </div>

</div>
