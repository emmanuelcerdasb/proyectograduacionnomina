@model IEnumerable<Permiso>

@{
    ViewBag.Title = "Mis Permisos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="table-card">
        <div class="card-header">
            <h5 class="mb-0">Mis Solicitudes de Permiso</h5>
        </div>

        <table class="table w-100 mt-3">
            <thead>
                <tr>
                    <th>Tipo Permiso</th>
                    <th>Fecha Inicio</th>
                    <th>Fecha Fin</th>
                    <th>Estado</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @item.TipoPermiso.nombre
                            (
                            @(item.TipoPermiso.es_administrativo
                                ? "Administrativo"
                                : (item.TipoPermiso.tiene_goce
                                    ? "Con goce de salario"
                                    : "Sin goce de salario"))
                            )
                        </td>
                        <td>@item.fecha_inicio.ToShortDateString()</td>
                        <td>@item.fecha_fin.ToShortDateString()</td>
                        <td>
                            <span class="badge bg-warning text-dark">@item.estado</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="form-footer">
            <a href="@Url.Action("Index")" class="btn btn-light cancel-btn">
                <i class="bi bi-arrow-left-circle me-1"></i> Volver
            </a>
        </div>
    </div>
</div>
