@model IEnumerable<ProyectoGraduacionNomina.Persona>

@{
    ViewBag.Title = "Personas";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    else if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

<div class="table-card-persona table-card">
    <div class="card-header">
        <h3 class="mb-2">Listado de Personas</h3>

        <div class="d-flex justify-content-end">
            <a href="@Url.Action("Create")" class="btn btn-primary-custom">
                <i class="bi bi-plus-circle me-1"></i> Nueva Persona
            </a>
        </div>
    </div>

    <div class="table-responsive-custom">
        <table class="table w-100 mt-3">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Apellido 1</th>
                    <th>Apellido 2</th>
                    <th>Cédula</th>
                    <th>Teléfono</th>
                    <th>Correo</th>
                    <th>Nacimiento</th>
                    <th>Creación</th>
                    <th>Tipo Cédula</th>

                    <!-- NUEVAS COLUMNAS -->
                    <th>Provincia</th>
                    <th>Cantón</th>
                    <th>Distrito</th>
                    <th>Dirección Exacta</th>

                    <th class="text-center">Operaciones</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    var direccion = item.Direccion;
                    var distrito = direccion?.Distrito;
                    var canton = distrito?.Canton;
                    var provincia = canton?.Provincia;

                    <tr>
                        <td>@item.nombre</td>
                        <td>@item.apellido1</td>
                        <td>@item.apellido2</td>
                        <td>@item.cedula</td>
                        <td>@item.telefono</td>
                        <td>@item.correo</td>

                        <td>
                            @(item.fecha_nacimiento != default(DateTime)
                                ? item.fecha_nacimiento.ToShortDateString()
                                : "")
                        </td>

                        <td>
                            @(item.fecha_creacion != default(DateTime)
                                ? item.fecha_creacion.ToShortDateString()
                                : "")
                        </td>

                        <td>
                            @(item.TipoCedula != null ? item.TipoCedula.tipo_cedula : "")
                        </td>

                        <!-- NUEVAS COLUMNAS -->
                        <td>@(provincia?.nombre ?? "N/A")</td>
                        <td>@(canton?.nombre ?? "N/A")</td>
                        <td>@(distrito?.nombre ?? "N/A")</td>
                        <td>@(direccion?.detalle ?? "Sin detalle")</td>

                        <td class="text-center">
                            @{
                                ViewBag.RowId = item.idPersona;
                                ViewBag.ControllerName = "Persona";
                            }
                            @Html.Partial("_RowActions")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="form-footer">
        <a href="@Url.Action("Index", "Mantenimiento")" class="btn btn-light cancel-btn">
            <i class="bi bi-arrow-left-circle me-1"></i> Volver
        </a>
    </div>
</div>
</div>
