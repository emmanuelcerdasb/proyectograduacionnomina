@model ProyectoGraduacionNomina.RegistroMarcacion

@{
    ViewBag.Title = "Detalles Marcación";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="form-card mt-4" style="max-width:700px;">
    <div class="form-header">
        <h2><i class="bi bi-info-circle me-2"></i>Detalles Marcación</h2>
    </div>

    <div class="form-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Empleado</dt>
            <dd class="col-sm-8">@((Model.Empleado != null) ? Model.Empleado.Persona.nombre + " " + Model.Empleado.Persona.apellido1 + " " + Model.Empleado.Persona.apellido2 : "N/A")</dd>

            <dt class="col-sm-4">Fecha</dt>
            <dd class="col-sm-8">@Model.fecha.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-4">Hora</dt>
            <dd class="col-sm-8">@Model.hora</dd>

            <dt class="col-sm-4">Tipo</dt>
            <dd class="col-sm-8">@Model.tipo</dd>

            <dt class="col-sm-4">Origen</dt>
            <dd class="col-sm-8">@Model.origen</dd>

            <dt class="col-sm-4">Observación</dt>
            <dd class="col-sm-8">@Model.observacion</dd>

            <dt class="col-sm-4">Fecha registro</dt>
            <dd class="col-sm-8">@Model.fecha_registro.ToString("dd/MM/yyyy HH:mm")</dd>
        </dl>
    </div>

    <div class="form-footer">
        <a href="@Url.Action("Index")" class="btn cancel-btn">
            <i class="bi bi-arrow-left-circle me-1"></i> Volver
        </a>
        <a href="@Url.Action("Edit", new { id = Model.idRegistroMarcacion })" class="btn btn-primary-custom">
            <i class="bi bi-pencil-square me-1"></i> Editar
        </a>
    </div>
</div>
