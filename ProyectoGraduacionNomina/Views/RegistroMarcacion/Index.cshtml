@model IEnumerable<ProyectoGraduacionNomina.RegistroMarcacion>

@{
    ViewBag.Title = "Registro de Marcaciones";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="table-card mt-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="mb-0">Registro de Marcaciones</h3>
        <a href="@Url.Action("Create")" class="btn btn-primary-custom">
            <i class="bi bi-plus-circle me-1"></i> Nueva Marcación
        </a>
    </div>

    <div class="table-responsive mt-3">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Empleado</th>
                    <th>Fecha</th>
                    <th>Hora</th>
                    <th>Tipo</th>
                    <th>Origen</th>
                    <th>Observación</th>
                    <th>Registrado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @(item.Empleado != null
                                    ? item.Empleado.Persona.nombre + " " + item.Empleado.Persona.apellido1 + " " + item.Empleado.Persona.apellido2
                                    : "N/A")
                            </td>
                            <td>@item.fecha.ToString("dd/MM/yyyy")</td>
                            <td>@(item.hora != null ? item.hora.ToString() : "-")</td>
                            <td>@item.tipo</td>
                            <td>@item.origen</td>
                            <td>@item.observacion</td>
                            <td>@item.fecha_registro.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-center">
                                @{
                                    ViewBag.RowId = item.idRegistroMarcacion;
                                    ViewBag.ControllerName = "RegistroMarcacion";
                                }
                                @Html.Partial("_RowActions")
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                            No hay marcaciones registradas.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="form-footer">
            <a href="@Url.Action("Index", "Consulta")" class="btn btn-light cancel-btn">
                <i class="bi bi-arrow-left-circle me-1"></i> Volver
            </a>
        </div>
    </div>
</div>
