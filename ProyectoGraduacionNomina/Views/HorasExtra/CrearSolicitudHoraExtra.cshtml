@{
    ViewBag.Title = "Solicitud de Horas Extra";
    bool esColaborador = User.IsInRole("Colaborador");
}

<div class="container mt-4">

    <div class="form-card">
        <div class="form-header">
            <h3>
                <i class="bi bi-alarm me-2"></i>
                Solicitud de Horas Extra
            </h3>
            <small class="text-muted">
                Complete la información requerida para solicitar horas extra
            </small>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            <div class="form-body">

                @if (!esColaborador)
                {
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Empleado</label>
                        @Html.DropDownList(
                            "empleadoId",
                            ViewBag.EmpleadoId as List<SelectListItem>,
                            "-- Seleccione --",
                            new { @class = "form-select modern-input" }
                        )
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label fw-semibold">Tipo de Hora Extra</label>
                    @Html.DropDownList(
                        "claseHoraExtraId",
                        ViewBag.ClaseHoraExtraId as List<SelectListItem>,
                        "-- Seleccione --",
                        new { @class = "form-select modern-input", required = "required" }
                    )
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Fecha</label>
                    <input type="date"
                           name="fecha"
                           class="form-control modern-input"
                           min="@ViewBag.FechaMin"
                           max="@ViewBag.FechaMax"
                           required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Cantidad de horas</label>
                    <input type="number"
                           name="cantidadHoras"
                           class="form-control modern-input"
                           step="0.5"
                           min="0.5"
                           required />
                </div>

                <div class="form-footer">
                    <a href="@Url.Action("Index")" class="btn btn-light cancel-btn">
                        <i class="bi bi-arrow-left-circle me-1"></i> Volver
                    </a>
                    <button type="submit" class="btn btn-primary-custom">
                        <i class="bi bi-send me-1"></i> Enviar solicitud
                    </button>
                </div>

            </div>
        }

        
    </div>
</div>
