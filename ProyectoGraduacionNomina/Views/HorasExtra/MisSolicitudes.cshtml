@model IEnumerable<ProyectoGraduacionNomina.SolicitudHorasExtra>

@{
    ViewBag.Title = "Mis Solicitudes de Horas Extra";
}

<div class="container mt-4">

    <div class="table-card">
        <div class="card-header">
            <h3 class="mb-1">
                <i class="bi bi-list-check me-2"></i>
                Mis Solicitudes de Horas Extra
            </h3>
            <small class="text-muted">
                Historial de solicitudes realizadas
            </small>
        </div>

        <table class="table w-100 mt-3">
            <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Horas</th>
                    <th>Tipo</th>
                    <th>Estado</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted">
                            No ha realizado solicitudes de horas extra.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.HoraExtra.fecha.ToShortDateString()</td>
                            <td>@item.HoraExtra.cantidad_horas</td>
                            <td>@item.HoraExtra.ClaseHoraExtra.nombre</td>
                            <td>
                                <span class="badge
                                    @(item.estado == "APROBADA" ? "bg-success" :
                                      item.estado == "RECHAZADA" ? "bg-danger" : "bg-warning text-dark")">
                                    @item.estado
                                </span>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
        <div class="form-footer">
            <a href="@Url.Action("Index")" class="btn btn-light cancel-btn">
                <i class="bi bi-arrow-left-circle me-1"></i> Volver
            </a>
        </div>
    </div>
</div>
