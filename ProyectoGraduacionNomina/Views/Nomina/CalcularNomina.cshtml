@{
    ViewBag.Title = "Cálculo de Nómina";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var anioActual = DateTime.Today.Year;
}

<div class="container mt-4">

    <div class="table-card">
        <div class="card-header">
            <h3 class="mb-2">Cálculo de nómina</h3>
            <small class="text-muted">Seleccione el período y el empleado</small>
        </div>

        <div class="p-3">
            <form method="post" action="@Url.Action("CalcularNomina", "Nomina")">
                @Html.AntiForgeryToken()

                <div class="row g-3">

                    <!-- EMPLEADO -->
                    <div class="col-md-4">
                        <label class="form-label">Empleado</label>
                        @Html.DropDownList(
                            "empleadoId",
                            ViewBag.EmpleadoId as IEnumerable<SelectListItem>,
                            "-- Seleccione un empleado --",
                            new { @class = "form-select", required = "required" }
                        )
                    </div>

                    <!-- MES -->
                    <div class="col-md-4">
                        <label class="form-label">Mes</label>
                        <select name="mes" class="form-select" required>
                            <option value="">Seleccione un mes</option>
                            <option value="1">Enero</option>
                            <option value="2">Febrero</option>
                            <option value="3">Marzo</option>
                            <option value="4">Abril</option>
                            <option value="5">Mayo</option>
                            <option value="6">Junio</option>
                            <option value="7">Julio</option>
                            <option value="8">Agosto</option>
                            <option value="9">Septiembre</option>
                            <option value="10">Octubre</option>
                            <option value="11">Noviembre</option>
                            <option value="12">Diciembre</option>
                        </select>
                    </div>

                    <!-- AÑO -->
                    <div class="col-md-4">
                        <label class="form-label">Año</label>
                        <select name="anno" class="form-select" required>
                            <option value="">Seleccione un año</option>
                            @for (int a = anioActual; a >= anioActual - 5; a--)
                            {
                                <option value="@a">@a</option>
                            }
                        </select>
                    </div>

                </div>

                <div class="form-footer">
                    <a href="@Url.Action("Index", "Home")" class="btn btn-light cancel-btn">
                        <i class="bi bi-arrow-left-circle me-1"></i> Volver
                    </a>
                    <button type="submit" class="btn btn-primary-custom">
                        <i class="bi bi-calculator me-1"></i> Calcular nómina
                    </button>
                </div>

            </form>
        </div>
    </div>

</div>
