@model ProyectoGraduacionNomina.Servicios.ResumenAsistenciaMensual

@{
    ViewBag.Title = "Resumen Mensual";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <div class="table-card">
        <div class="card-header">
            <h3 class="mb-2">Resumen mensual de asistencia</h3>
            <small class="text-muted">
                Mes: @Model.Mes / Año: @Model.Anno   |   Colaborador: @ViewBag.NombreEmpleado   |   Cédula:@ViewBag.CedulaEmpleado
            </small>
        </div>

        <div class="row g-3 p-3">

            <div class="col-md-3">
                <div class="card p-3 text-center">
                    <small class="text-muted">Días laborados</small>
                    <h3>@Model.DiasLaborados</h3>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card p-3 text-center">
                    <small class="text-muted">Ausencias</small>
                    <h3 class="text-danger">@Model.DiasAusencia</h3>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card p-3 text-center">
                    <small class="text-muted">Tardías</small>
                    <h3 class="text-warning">@Model.DiasConTardia</h3>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card p-3 text-center">
                    <small class="text-muted">Horas netas</small>
                    <h3>@Model.TotalHorasNetas</h3>
                </div>
            </div>

        </div>

        <div class="form-footer">
            <a href="@Url.Action("ResumenAsistenciaMensual", "Reportes")" class="btn btn-light cancel-btn">
                <i class="bi bi-arrow-left-circle me-1"></i> Volver
            </a>
        </div>
    </div>
</div>
