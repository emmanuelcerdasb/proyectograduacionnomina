@model IEnumerable<ProyectoGraduacionNomina.Servicios.ResultadoAsistenciaDiaria>

@{
    ViewBag.Title = "Reporte de Asistencia";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <div class="table-card">
        <div class="card-header">
            <h3 class="mb-2">Reporte de asistencia</h3>
            <small class="text-muted">
                Período: @ViewBag.FechaInicio al @ViewBag.FechaFin   |   Colaborador: @ViewBag.NombreEmpleado   |   Cédula:@ViewBag.CedulaEmpleado
            </small>
        </div>

        <table class="table w-100 mt-3">
            <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Entrada</th>
                    <th>Salida</th>
                    <th>Horas netas</th>
                    <th>Tardía</th>
                    <th>Ausencia</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in Model)
                {
                    <tr>
                        <td>@d.Fecha.ToString("dd/MM/yyyy")</td>
                        <td>@d.HoraEntrada</td>
                        <td>@d.HoraSalida</td>
                        <td>@d.HorasNetas</td>
                        <td>
                            @if (d.TieneTardia)
                            {
                                <span class="badge bg-warning text-dark">
                                    @d.MinutosTardia min
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success">No</span>
                            }
                        </td>
                        <td>
                            @if (d.EsAusencia)
                            {
                                <span class="badge bg-danger">Sí</span>
                            }
                            else
                            {
                                <span class="badge bg-success">No</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="form-footer">
            <a href="@Url.Action("AsistenciaEmpleado", "Reportes")" class="btn btn-light cancel-btn">
                <i class="bi bi-arrow-left-circle me-1"></i> Volver
            </a>
        </div>
    </div>
</div>
