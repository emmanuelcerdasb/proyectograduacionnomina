@model ProyectoGraduacionNomina.Empleado

@{
    ViewBag.Title = "Detalles Colaborador";
}

<div class="form-card">
    <div class="form-header">
        <h2><i class="bi bi-person-lines-fill me-2"></i>Detalles del Colaborador</h2>
    </div>

    <div class="form-body">
        <dl class="row">
            <dt class="col-sm-3">Cédula</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Persona.cedula)</dd>

            <dt class="col-sm-3">Persona</dt>
            <dd class="col-sm-9">@((Model.Persona != null) ? Model.Persona.nombre + " " + Model.Persona.apellido1 : "")</dd>

            <dt class="col-sm-3">Usuario(credencial)</dt>
            <dd class="col-sm-9">@((Model.Credencial != null) ? Model.Credencial.usuario : "")</dd>

            <dt class="col-sm-3">Puesto</dt>
            <dd class="col-sm-9">@((Model.Puesto != null) ? Model.Puesto.nombre : "")</dd>

            <dt class="col-sm-3">Jornada</dt>
            <dd class="col-sm-9">@((Model.Jornada != null) ? Model.Jornada.nombre : "")</dd>

            <dt class="col-sm-3">Horario Semanal</dt>
            <dd class="col-sm-9">@((Model.HorarioSemanal != null) ? Model.HorarioSemanal.nombre : "No asignado")</dd>

            <dt class="col-sm-3">Fecha ingreso</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.fecha_ingreso)</dd>

            <dt class="col-sm-3">Fecha salida</dt>
            <dd class="col-sm-9">@((Model.fecha_salida.HasValue) ? Model.fecha_salida.Value.ToShortDateString() : "—")</dd>

            <dt class="col-sm-3">Estado</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.estado)</dd>
        </dl>
    </div>

    <div class="form-footer">
        <a href="@Url.Action("Index")" class="btn btn-light cancel-btn">
            <i class="bi bi-arrow-left-circle me-1"></i> Volver
        </a>

        <div>
            <a href="@Url.Action("Edit", new { id = Model.idEmpleado })" class="btn btn-primary-custom">
                <i class="bi bi-pencil-square me-1"></i> Editar
            </a>
        </div>
    </div>
</div>
