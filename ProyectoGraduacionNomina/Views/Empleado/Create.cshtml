@model ProyectoGraduacionNomina.Empleado

@{
    ViewData["Title"] = "Registrar Colaborador";
}

<div class="form-card shadow-sm p-4">

    <div class="form-header">
        <h2><i class="bi bi-person-plus-fill me-2"></i>Crear Colaborador</h2>
    </div>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="row g-3">

            <div class="col-md-6">
                @Html.LabelFor(m => m.Persona_idPersona, "Persona", new { @class = "form-label fw-semibold" })
                @Html.DropDownList("Persona_idPersona", null, "-- Seleccione Persona --", new { @class = "form-select modern-input" })
                @Html.ValidationMessageFor(m => m.Persona_idPersona, "", new { @class = "text-danger" })
            </div>

            <div class="col-md-6">
                @Html.LabelFor(m => m.Credencial_idCredencial, "Credencial", new { @class = "form-label fw-semibold" })
                @Html.DropDownList("Credencial_idCredencial", null, "-- Seleccione Credencial --", new { @class = "form-select modern-input" })
                @Html.ValidationMessageFor(m => m.Credencial_idCredencial, "", new { @class = "text-danger" })
            </div>

            <div class="col-md-6">
                @Html.LabelFor(m => m.Puesto_idPuesto, "Puesto", new { @class = "form-label fw-semibold" })
                @Html.DropDownList("Puesto_idPuesto", null, "-- Seleccione Puesto --", new { @class = "form-select modern-input" })
                @Html.ValidationMessageFor(m => m.Puesto_idPuesto, "", new { @class = "text-danger" })
            </div>

            <div class="col-md-6">
                @Html.LabelFor(m => m.Jornada_idJornada, "Jornada", new { @class = "form-label fw-semibold" })
                @Html.DropDownList("Jornada_idJornada", null, "-- Seleccione Jornada --", new { @class = "form-select modern-input" })
                @Html.ValidationMessageFor(m => m.Jornada_idJornada, "", new { @class = "text-danger" })
            </div>

            <!-- 🔴 CAMBIO CLAVE: HORARIO SEMANAL -->
            <div class="col-md-6">
                @Html.LabelFor(m => m.HorarioSemanal_idHorarioSemanal, "Horario Semanal", new { @class = "form-label fw-semibold" })
                @Html.DropDownList(
                    "HorarioSemanal_idHorarioSemanal",
                    null,
                    "-- Seleccione Horario Semanal --",
                    new { @class = "form-select modern-input" }
                )
                @Html.ValidationMessageFor(m => m.HorarioSemanal_idHorarioSemanal, "", new { @class = "text-danger" })
            </div>

            <div class="col-md-6">
                @Html.LabelFor(m => m.fecha_ingreso, "Fecha Ingreso", new { @class = "form-label fw-semibold" })
                @Html.EditorFor(m => m.fecha_ingreso, new { htmlAttributes = new { @class = "form-control modern-input", type = "date" } })
                @Html.ValidationMessageFor(m => m.fecha_ingreso, "", new { @class = "text-danger" })
            </div>

            <div class="col-md-6">
                @Html.LabelFor(m => m.fecha_salida, "Fecha Salida", new { @class = "form-label fw-semibold" })
                @Html.EditorFor(m => m.fecha_salida, new { htmlAttributes = new { @class = "form-control modern-input", type = "date" } })
                @Html.ValidationMessageFor(m => m.fecha_salida, "", new { @class = "text-danger" })
            </div>

            <div class="col-md-6">
                @Html.LabelFor(m => m.estado, "Estado", new { @class = "form-label fw-semibold" })
                @Html.DropDownListFor(
                    m => m.estado,
                    new SelectList(new[] { "Activo", "Desactivado" }),
                    "-- Seleccione Estado --",
                    new { @class = "form-select modern-input" }
                )
                @Html.ValidationMessageFor(m => m.estado, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="mt-4 d-flex justify-content-between">
            <a href="@Url.Action("Index")" class="btn btn-light cancel-btn">
                <i class="bi bi-arrow-left-circle me-1"></i> Volver
            </a>
            <button type="submit" class="btn btn-primary-custom">
                <i class="bi bi-save2 me-1"></i> Guardar
            </button>
        </div>
    }
</div>
