@model IEnumerable<ProyectoGraduacionNomina.Empleado>

@{
    ViewData["Title"] = "Listado de Colaboradores";
}

<div class="table-card shadow-sm p-4">
    <div class="card-header">
        <h3 class="mb-2">Listado de Colaboradores</h3>

        <div class="d-flex justify-content-end">
            <a href="@Url.Action("Create")" class="btn btn-primary-custom">
                <i class="bi bi-plus-circle me-1"></i> Nuevo Empleado
            </a>
        </div>
    </div>


    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Persona</th>
                    <th>Credencial</th>
                    <th>Puesto</th>
                    <th>Jornada</th>
                    <th>Horario Semanal</th>
                    <th>Fecha Ingreso</th>
                    <th>Fecha Salida</th>
                    <th>Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Persona.nombre</td>
                            <td>@item.Credencial.usuario</td>
                            <td>@item.Puesto.nombre</td>
                            <td>@item.Jornada.nombre</td>
                            <td>@(item.HorarioSemanal != null ? item.HorarioSemanal.nombre : "No asignado")</td>
                            <td>@item.fecha_ingreso.ToString("dd/MM/yyyy")</td>
                            <td>@(item.fecha_salida.HasValue ? item.fecha_salida.Value.ToString("dd/MM/yyyy") : "-")</td>
                            <td>@item.estado</td>
                            <td class="text-center">
                                @Html.Partial("_RowActions", new ViewDataDictionary(ViewData)
                                {
                                    { "RowId", item.idEmpleado },
                                    { "ControllerName", "Empleado" }
                                })
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">
                            <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                            No hay empleados registrados.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="form-footer">
            <a href="@Url.Action("Index", "Mantenimiento")" class="btn btn-light cancel-btn">
                <i class="bi bi-arrow-left-circle me-1"></i> Volver
            </a>
        </div>
    </div>
</div>
