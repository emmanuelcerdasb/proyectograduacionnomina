@model ProyectoGraduacionNomina.EvaluacionPersonal

@{
    ViewBag.Title = "Detalle Evaluacion";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string periodo = (Model.semestre == 1 ? "Enero - Junio" : "Julio - Diciembre") + " " + Model.anio;
    string badgeColor = Model.calificacion == "Excelente" ? "bg-success"
                      : Model.calificacion == "Bueno"     ? "bg-primary"
                      : Model.calificacion == "Regular"   ? "bg-warning text-dark"
                      : "bg-danger";
}

<div class="container mt-4">
    <div class="table-card">

        <div class="card-header">
            <h3 class="mb-1">
                <i class="bi bi-star me-2"></i>
                Detalle de Evaluacion
            </h3>
            <small class="text-muted">Periodo: @periodo &mdash; Evaluado el @Model.fecha_evaluacion.ToString("dd/MM/yyyy")</small>
        </div>

        <div class="p-4">

            @* ---- Empleado ---- *@
            <h6 class="text-primary mb-2">Empleado evaluado</h6>
            <div class="row mb-4">
                <div class="col-md-4">
                    <small class="text-muted d-block">Nombre</small>
                    <strong>@Model.Empleado.Persona.nombre @Model.Empleado.Persona.apellido1 @Model.Empleado.Persona.apellido2</strong>
                </div>
                <div class="col-md-3">
                    <small class="text-muted d-block">Cedula</small>
                    <strong>@Model.Empleado.Persona.cedula</strong>
                </div>
                <div class="col-md-3">
                    <small class="text-muted d-block">Puesto</small>
                    <strong>@Model.Empleado.Puesto.nombre</strong>
                </div>
                <div class="col-md-2">
                    <small class="text-muted d-block">Evaluador</small>
                    <strong>@Model.evaluador</strong>
                </div>
            </div>

            @* ---- Criterios ---- *@
            <h6 class="text-primary mb-2">Criterios evaluados</h6>
            <table class="table mb-4">
                <thead>
                    <tr>
                        <th>Criterio</th>
                        <th class="text-center" style="width:120px">Nota (/ 10)</th>
                        <th style="width:200px">Barra</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var criterios = new[] {
                            new { Nombre = "Puntualidad y asistencia",   Nota = Model.nota_puntualidad },
                            new { Nombre = "Calidad del trabajo",         Nota = Model.nota_calidad },
                            new { Nombre = "Trabajo en equipo",           Nota = Model.nota_trabajo_equipo },
                            new { Nombre = "Iniciativa y proactividad",   Nota = Model.nota_iniciativa },
                            new { Nombre = "Cumplimiento de metas",       Nota = Model.nota_cumplimiento }
                        };
                    }
                    @foreach (var c in criterios)
                    {
                        int pct = (int)(c.Nota * 10);
                        string barColor = pct >= 90 ? "bg-success" : pct >= 70 ? "bg-primary" : pct >= 50 ? "bg-warning" : "bg-danger";
                        <tr>
                            <td>@c.Nombre</td>
                            <td class="text-center fw-bold">@c.Nota.ToString("N2")</td>
                            <td>
                                <div class="progress" style="height:18px;">
                                    <div class="progress-bar @barColor" style="width:@pct%">@c.Nota.ToString("N1")</div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-light">
                    <tr>
                        <th>Nota final (promedio)</th>
                        <th class="text-center fs-5">@Model.nota_final.ToString("N2")</th>
                        <th><span class="badge @badgeColor fs-6">@Model.calificacion</span></th>
                    </tr>
                </tfoot>
            </table>

            @if (!string.IsNullOrWhiteSpace(Model.comentarios))
            {
                <div class="alert alert-light mb-4">
                    <i class="bi bi-chat-text me-1"></i> <strong>Comentarios:</strong> @Model.comentarios
                </div>
            }

            <a href="@Url.Action("Index", "Evaluacion")" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Volver
            </a>

        </div>
    </div>
</div>
