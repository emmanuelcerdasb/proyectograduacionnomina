@model ProyectoGraduacionNomina.Horario

@{
    ViewBag.Title = "Eliminar Horario";
}

<div class="form-card delete-card">
    <div class="form-header text-danger">
        <h2 class="text-danger">
            <i class="bi bi-trash me-2"></i>Eliminar Horario
        </h2>

        <small class="text-muted">
            Horario semanal: <strong>@ViewBag.HorarioSemanalNombre</strong>
        </small>
    </div>

    <div class="form-body">
        <p class="text-danger">
            ¿Está seguro de eliminar el horario:
            <strong>@Model.dia_semana</strong>
            de <strong>@Model.hora_inicio</strong>
            hasta las <strong>@Model.hora_fin</strong>?
        </p>

        <div class="mb-3">
            <label class="form-label fw-semibold text-secondary">Día de la semana</label>
            <div class="form-control modern-input readonly-field">
                @Html.DisplayFor(model => model.dia_semana)
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold text-secondary">Hora inicio</label>
            <div class="form-control modern-input readonly-field">
                @Html.DisplayFor(model => model.hora_inicio)
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold text-secondary">Hora fin</label>
            <div class="form-control modern-input readonly-field">
                @Html.DisplayFor(model => model.hora_fin)
            </div>
        </div>
    </div>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.idHorario)
        @Html.HiddenFor(m => m.HorarioSemanal_idHorarioSemanal)

        <div class="form-footer d-flex justify-content-between align-items-center mt-3">
            <a href="@Url.Action(
                "Details",
                "HorarioSemanal",
                new { id = Model.HorarioSemanal_idHorarioSemanal }
            )"
               class="btn btn-light cancel-btn">
                <i class="bi bi-arrow-left-circle me-1"></i> Cancelar
            </a>

            <button type="submit" class="btn btn-danger shadow-sm">
                <i class="bi bi-trash me-1"></i> Eliminar
            </button>
        </div>
    }
</div>
