@model IEnumerable<ProyectoGraduacionNomina.Horario>

@{
    ViewBag.Title = "Horarios";
}

<div class="container mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    else if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="table-card">
        <div class="card-header">
            <h3 class="mb-2">Listado de Horarios</h3>
            <small class="text-muted">
                Los horarios se gestionan desde el Horario Semanal
            </small>
        </div>

        <table class="table w-100 mt-3">
            <thead>
                <tr>
                    <th>Día</th>
                    <th>Hora Inicio</th>
                    <th>Hora Fin</th>
                    <th class="text-center">Operaciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.dia_semana</td>
                        <td>@item.hora_inicio</td>
                        <td>@item.hora_fin</td>
                        <td class="text-center">
                            @{
                                ViewBag.RowId = item.idHorario;
                                ViewBag.ControllerName = "Horario";

                                ViewBag.ExtraAction = "Details";
                                ViewBag.ExtraController = "HorarioSemanal";
                                ViewBag.ExtraId = item.HorarioSemanal_idHorarioSemanal ?? 0;

                                ViewBag.ExtraTitle = "Ver horario semanal";
                                ViewBag.ExtraIcon = "bi-calendar-week";
                                ViewBag.ExtraCss = "btn-outline-primary";
                            }
                            @Html.Partial("_RowActions")


                        </td>

                    </tr>
                }
            </tbody>
        </table>

        <div class="form-footer">
            <a href="@Url.Action("Index", "Mantenimiento")" class="btn btn-light cancel-btn">
                <i class="bi bi-arrow-left-circle me-1"></i> Volver
            </a>
        </div>
    </div>
</div>
