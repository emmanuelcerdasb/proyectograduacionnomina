@model ProyectoGraduacionNomina.Horario

@{
    ViewBag.Title = "Agregar día al horario";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <div class="table-card">

        <!-- ===============================
             HEADER
             =============================== -->
        <div class="card-header">
            <h3 class="mb-2">
                <i class="bi bi-clock me-1"></i>
                Agregar día al horario semanal
            </h3>
            <small class="text-muted">
                @ViewBag.HorarioSemanalNombre
            </small>
        </div>

        <div class="p-3">

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                <!-- FK OCULTA -->
                @Html.HiddenFor(m => m.HorarioSemanal_idHorarioSemanal)


                @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                <!-- ===============================
             DÍA DE LA SEMANA
             =============================== -->
                <div class="mb-3">
                    @Html.LabelFor(m => m.dia_semana, "Día de la Semana", new { @class = "form-label" })
                    @Html.EditorFor(m => m.dia_semana, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(m => m.dia_semana, "", new { @class = "text-danger" })
                </div>

                <!-- ===============================
             HORA INICIO
             =============================== -->
                <div class="mb-3">
                    @Html.LabelFor(m => m.hora_inicio, "Hora Inicio Laboral", new { @class = "form-label" })
                    @Html.EditorFor(m => m.hora_inicio, new { htmlAttributes = new { @class = "form-control", type = "time" } })
                    @Html.ValidationMessageFor(m => m.hora_inicio, "", new { @class = "text-danger" })
                </div>

                <!-- ===============================
             HORA FIN
             =============================== -->
                <div class="mb-3">
                    @Html.LabelFor(m => m.hora_fin,"Hora Fin Laboral", new { @class = "form-label" })
                    @Html.EditorFor(m => m.hora_fin, new { htmlAttributes = new { @class = "form-control", type = "time" } })
                    @Html.ValidationMessageFor(m => m.hora_fin, "", new { @class = "text-danger" })
                </div>

                <!-- ===============================
             FOOTER
             =============================== -->
                <div class="form-footer d-flex justify-content-between">
                    <a href="@Url.Action("Details", "HorarioSemanal", new { id = Model.HorarioSemanal_idHorarioSemanal })"
                       class="btn btn-light cancel-btn">
                        <i class="bi bi-arrow-left-circle me-1"></i>
                        Volver
                    </a>

                    <button type="submit" class="btn btn-primary-custom">
                        <i class="bi bi-check-circle me-1"></i>
                        Guardar día
                    </button>
                </div>
            }

        </div>
    </div>
</div>
