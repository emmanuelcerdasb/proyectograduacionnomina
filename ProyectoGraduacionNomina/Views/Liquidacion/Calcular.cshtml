@{
    ViewBag.Title = "Calcular Liquidacion";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="table-card">

        <div class="card-header">
            <h3 class="mb-1">
                <i class="bi bi-calculator me-2"></i>
                Calcular Liquidacion
            </h3>
            <small class="text-muted">Ingrese los datos para calcular la liquidacion laboral</small>
        </div>

        <div class="p-4">

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-circle me-1"></i> @TempData["Error"]
                </div>
            }

            @using (Html.BeginForm("Calcular", "Liquidacion", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                <div class="row g-3">

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Empleado</label>
                        @Html.DropDownList("empleadoId",
                            ViewBag.EmpleadoId as IEnumerable<SelectListItem>,
                            "-- Seleccione un empleado --",
                            new { @class = "form-select" })
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Tipo de liquidacion</label>
                        @Html.DropDownList("tipoLiquidacionId",
                            ViewBag.TipoLiquidacionId as IEnumerable<SelectListItem>,
                            "-- Seleccione tipo --",
                            new { @class = "form-select" })
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Fecha de liquidacion</label>
                        <input type="date" name="fechaLiquidacion" class="form-control"
                               value="@ViewBag.FechaHoy" required />
                    </div>

                    <div class="col-md-8">
                        <label class="form-label fw-semibold">Observaciones</label>
                        <input type="text" name="observaciones" class="form-control"
                               placeholder="Motivo u observaciones adicionales" maxlength="500" />
                    </div>

                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary-custom">
                        <i class="bi bi-calculator me-1"></i> Calcular
                    </button>
                    <a href="@Url.Action("Index", "Liquidacion")" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Volver
                    </a>
                </div>
            }

        </div>
    </div>
</div>
