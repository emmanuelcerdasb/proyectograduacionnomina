@model IEnumerable<ProyectoGraduacionNomina.Liquidacion>

@{
    ViewBag.Title = "Liquidaciones";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="table-card">

        <div class="card-header">
            <h3 class="mb-1">
                <i class="bi bi-person-x me-2"></i>
                Liquidaciones
            </h3>
            <small class="text-muted">Liquidaciones laborales registradas en el sistema</small>
        </div>

        <div class="p-3">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-circle me-1"></i> @TempData["Error"]
                </div>
            }

            <div class="d-flex justify-content-end mb-3">
                <a href="@Url.Action("Calcular", "Liquidacion")" class="btn btn-primary-custom">
                    <i class="bi bi-calculator me-1"></i> Nueva liquidacion
                </a>
            </div>

            @if (!Model.Any())
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-1"></i>
                    No hay liquidaciones registradas.
                </div>
            }
            else
            {
                <table class="table w-100">
                    <thead>
                        <tr>
                            <th>Empleado</th>
                            <th>Cedula</th>
                            <th>Tipo</th>
                            <th>Fecha</th>
                            <th>Total percepciones</th>
                            <th>Neto a pagar</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var liq in Model)
                        {
                            <tr>
                                <td>@liq.Empleado.Persona.nombre @liq.Empleado.Persona.apellido1 @liq.Empleado.Persona.apellido2</td>
                                <td>@liq.Empleado.Persona.cedula</td>
                                <td><span class="badge bg-secondary">@liq.TipoLiquidacion.nombre</span></td>
                                <td>@liq.fecha.ToString("dd/MM/yyyy")</td>
                                <td class="text-end">&#x20A1;@liq.total_percepciones.ToString("N2")</td>
                                <td class="text-end fw-bold">&#x20A1;@liq.neto_pagar.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

        </div>
    </div>
</div>
