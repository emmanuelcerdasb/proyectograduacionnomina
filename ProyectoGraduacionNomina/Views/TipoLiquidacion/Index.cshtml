@model IEnumerable<ProyectoGraduacionNomina.TipoLiquidacion>

@{
    ViewBag.Title = "Tipos de Liquidación";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0"><i class="bi bi-file-earmark-text me-2"></i>Tipos de Liquidación</h3>
            <small class="text-muted">Catálogo de motivos y reglas de liquidación laboral</small>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("Index","Mantenimiento")" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left me-1"></i> Mantenimientos
            </a>
            <a href="@Url.Action("Crear","TipoLiquidacion")" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-circle me-1"></i> Nuevo tipo
            </a>
        </div>
    </div>

    <div class="table-card">
        <table class="table w-100 mb-0">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th class="text-center">Cesantía</th>
                    <th class="text-center">Preaviso</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No hay tipos registrados.</td></tr>
                }
                @foreach (var t in Model)
                {
                    <tr>
                        <td><code>@t.codigo</code></td>
                        <td class="fw-semibold">@t.nombre</td>
                        <td><small class="text-muted">@t.descripcion</small></td>
                        <td class="text-center">
                            @if (t.aplica_cesantia) { <i class="bi bi-check-circle-fill text-success"></i> }
                            else { <i class="bi bi-x-circle text-muted"></i> }
                        </td>
                        <td class="text-center">
                            @if (t.aplica_preaviso) { <i class="bi bi-check-circle-fill text-success"></i> }
                            else { <i class="bi bi-x-circle text-muted"></i> }
                        </td>
                        <td class="text-center">
                            <div class="row-actions">
                                <a href="@Url.Action("Editar","TipoLiquidacion", new { id = t.idTipoLiquidacion })"
                                   class="icon-btn btn-warning" title="Editar">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                @using (Html.BeginForm("Eliminar", "TipoLiquidacion", new { id = t.idTipoLiquidacion }, FormMethod.Post, new { style = "display:inline" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="icon-btn btn-danger" title="Eliminar"
                                            onclick="return confirm('¿Eliminar este tipo?')">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
