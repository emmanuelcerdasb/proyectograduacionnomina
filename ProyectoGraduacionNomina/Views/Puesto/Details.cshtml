@model ProyectoGraduacionNomina.Puesto
@{
    ViewBag.Title = "Detalles del Puesto";
}

<div class="form-card">
    <div class="form-header">
        <h2><i class="bi bi-info-circle-fill me-2"></i>Detalles del Puesto</h2>
    </div>

    <div class="form-body">
        <dl class="row">
            <dt class="col-sm-4 fw-semibold">Puesto</dt>
            <dd class="col-sm-8">@Html.DisplayFor(m => m.nombre)</dd>

            <dt class="col-sm-4 fw-semibold">Planilla</dt>
            <dd class="col-sm-8">@Html.DisplayFor(m => m.planilla)</dd>

            <dt class="col-sm-4 fw-semibold">Salario Base</dt>
            <dd class="col-sm-8">@Html.DisplayFor(m => m.salario_base)</dd>

            <dt class="col-sm-4 fw-semibold">Salario por Hora</dt>
            <dd class="col-sm-8">@Html.DisplayFor(m => m.salario_por_hora)</dd>

            <dt class="col-sm-4 fw-semibold">Estado</dt>
            <dd class="col-sm-8">@Html.DisplayFor(m => m.estado)</dd>

            @*
        <dt class="col-sm-4 fw-semibold">Fecha Inicio</dt>
        <dd class="col-sm-8">@Html.DisplayFor(m => m.fecha_inicio)</dd>

        <dt class="col-sm-4 fw-semibold">Fecha Fin</dt>
        <dd class="col-sm-8">@Html.DisplayFor(m => m.fecha_fin)</dd>*@

            <dt class="col-sm-4 fw-semibold">Departamento</dt>
            <dd class="col-sm-8">@Html.DisplayFor(m => m.Departamento.nombre)</dd>
        </dl>
    </div>

    <div class="form-footer d-flex justify-content-between align-items-center">
        <a href="@Url.Action("Index")" class="btn btn-light cancel-btn">
            <i class="bi bi-arrow-left-circle me-1"></i> Volver
        </a>
        <a href="@Url.Action("Edit", new { id = Model.idPuesto })" class="btn btn-primary-custom">
            <i class="bi bi-pencil-square me-1"></i> Editar
        </a>
    </div>
</div>
