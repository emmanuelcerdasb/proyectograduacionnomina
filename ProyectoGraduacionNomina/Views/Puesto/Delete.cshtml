@model ProyectoGraduacionNomina.Puesto
@{
    ViewBag.Title = "Eliminar Puesto";
}

<div class="form-card">
    <div class="form-header">
        <h2 class="text-danger"><i class="bi bi-trash me-2"></i>Eliminar Puesto</h2>
    </div>

    <div class="form-body">
        <p class="text-danger">¿Está seguro de eliminar el puesto <strong>@Model.nombre</strong>?</p>

        <dl class="row">
            <dt class="col-sm-4 fw-semibold">Puesto</dt>
            <dd class="col-sm-8">@Html.DisplayFor(m => m.nombre)</dd>

            <dt class="col-sm-4 fw-semibold">Departamento</dt>
            <dd class="col-sm-8">@Html.DisplayFor(m => m.Departamento.nombre)</dd>

            <dt class="col-sm-4 fw-semibold">Salario Base</dt>
            <dd class="col-sm-8">@Html.DisplayFor(m => m.salario_base)</dd>

            <dt class="col-sm-4 fw-semibold">Estado</dt>
            <dd class="col-sm-8">@Html.DisplayFor(m => m.estado)</dd>
        </dl>
    </div>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="form-footer d-flex justify-content-between align-items-center mt-3">
            <a href="@Url.Action("Index")" class="btn btn-light cancel-btn">
                <i class="bi bi-arrow-left-circle me-1"></i> Cancelar
            </a>
            <button type="submit" class="btn btn-danger shadow-sm">
                <i class="bi bi-trash me-1"></i> Eliminar
            </button>
        </div>
    }
</div>
