@model IEnumerable<ProyectoGraduacionNomina.Puesto>

@{
    ViewData["Title"] = "Listado de Puestos";
}

<div class="table-card shadow-sm p-4">
    <div class="card-header">
        <h3 class="mb-2">Listado de Puestos</h3>

        <div class="d-flex justify-content-end">
            <a href="@Url.Action("Create")" class="btn btn-primary-custom">
                <i class="bi bi-plus-circle me-1"></i> Nuevo Puestos
            </a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Planilla</th>
                    <th>Salario Base</th>
                    <th>Salario por Hora</th>
                    <th>Estado</th>
                    @*<th>Fecha Inicio</th>
                    <th>Fecha Fin</th>*@
                    <th>Departamento</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.nombre</td>
                            <td>@(item.planilla ? "Sí" : "No")</td>
                            <td>@item.salario_base.ToString("C2", new System.Globalization.CultureInfo("es-CR"))</td>
                            <td>@item.salario_por_hora.ToString("C2", new System.Globalization.CultureInfo("es-CR"))</td>
                            <td>@item.estado</td>
                            @*<td>@item.fecha_inicio.ToString("dd/MM/yyyy")</td>
                            <td>@item.fecha_fin.ToString("dd/MM/yyyy")</td>*@
                            <td>@item.Departamento.nombre</td>
                            <td class="text-center">
                                @Html.Partial("_RowActions", new ViewDataDictionary(ViewData)
                                {
                                    { "RowId", item.idPuesto },
                                    { "ControllerName", "Puesto" }
                                })
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">
                            <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                            No hay puestos registrados.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="form-footer">
            <a href="@Url.Action("Index", "Mantenimiento")" class="btn btn-light cancel-btn">
                <i class="bi bi-arrow-left-circle me-1"></i> Volver
            </a>
        </div>
    </div>
        </div>
