@{
    ViewBag.Title = "Calcular Aguinaldo";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var anioActual = (int)ViewBag.AnioActual;
}

<div class="container mt-4">
    <div class="table-card">
        <div class="card-header">
            <h3 class="mb-2">Calcular Aguinaldo</h3>
            <small class="text-muted">Seleccione el empleado y el anio a calcular</small>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                <i class="bi bi-exclamation-triangle me-1"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="p-3">
            <form method="post" action="@Url.Action("Calcular", "Aguinaldo")">
                @Html.AntiForgeryToken()

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Empleado</label>
                        @Html.DropDownList("empleadoId",
                            ViewBag.EmpleadoId as IEnumerable<SelectListItem>,
                            "-- Seleccione un empleado --",
                            new { @class = "form-select", required = "required" })
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Anio</label>
                        <select name="anio" class="form-select" required>
                            <option value="">Seleccione un anio</option>
                            @for (int a = anioActual; a >= anioActual - 5; a--)
                            {
                                <option value="@a">@a</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="alert alert-info mt-3">
                    <i class="bi bi-info-circle me-1"></i>
                    <strong>Periodo CR:</strong> 1 de diciembre del anio anterior al 30 de noviembre del anio seleccionado.
                    El monto es la sumatoria de salarios brutos del periodo dividido entre 12.
                </div>

                <div class="form-footer">
                    <a href="@Url.Action("Index", "Aguinaldo")" class="btn btn-light cancel-btn">
                        <i class="bi bi-arrow-left-circle me-1"></i> Volver
                    </a>
                    <button type="submit" class="btn btn-primary-custom">
                        <i class="bi bi-calculator me-1"></i> Calcular
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>